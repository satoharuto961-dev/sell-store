            <div class="sl-feature-sub">Learn CBT (Cognitive Behavioral Therapy) principles to permanently change the thought patterns that fuel your rage.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- REVIEWS -->
  <div class="sl-section" style="background: var(--surface);">
    <div class="sl-section-inner">
      <div style="text-align: center; margin-bottom: 48px;">
        <div class="sl-label">Verified Reviews</div>
