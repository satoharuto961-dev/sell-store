{% comment %}
  Therapy Toolkit Landing Page
  Template: page.therapy-toolkit.liquid
  Product: ultimate-therapist-toolkit-1100-professional-therapy-resources
{% endcomment %}

{% assign tt = all_products['ultimate-therapist-toolkit-1100-professional-therapy-resources'] %}
{% assign tt_variant = tt.variants.first %}

<style>
  /* ── Hide theme chrome on this page only ── */
  .announce-bar,
  .site-header {
    display: none !important;
  }

  /* ── Reset ── */
  .tt-wrap * { box-sizing: border-box; }

  .tt-wrap {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #1f2937;
    line-height: 1.6;
    background: #f7f9fc;
  }

  /* ── HERO ── */
  .tt-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    color: white;
    padding: clamp(60px, 10vw, 120px) 20px;
    text-align: center;
  }

  .tt-hero-eyebrow {
    display: inline-block;
    background: rgba(255,107,0,0.2);
    border: 1px solid rgba(255,107,0,0.5);
    color: #ff9a4a;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    margin-bottom: 20px;
  }

  .tt-hero h1 {
    font-size: clamp(28px, 5vw, 54px);
    margin: 0 0 16px;
    font-weight: 800;
    line-height: 1.12;
    max-width: 860px;
    margin-inline: auto;
  }

  .tt-hero p {
    font-size: clamp(16px, 2.5vw, 20px);
    opacity: 0.85;
    max-width: 680px;
    margin: 0 auto 32px;
  }

  .tt-trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    font-size: 14px;
    opacity: 0.75;
  }

  .tt-trust-row span { display: flex; align-items: center; gap: 6px; }

  /* ── CTA Button ── */
  .tt-cta-btn {
    display: inline-block;
    padding: 18px 44px;
    background: #ff6b00;
    color: white !important;
    font-size: 18px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 800;
    border: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    line-height: 1;
  }

  .tt-cta-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 10px 28px rgba(255,107,0,0.45);
    color: white !important;
  }

  /* ── SECTION CONTAINER ── */
  .tt-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .tt-section-title {
    text-align: center;
    font-size: clamp(24px, 3vw, 36px);
    margin: 0 0 48px;
    font-weight: 800;
  }

  /* ── STAT GRID ── */
  .tt-stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 24px;
  }

  .tt-stat-card {
    background: white;
    padding: 30px 20px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    text-align: center;
    font-size: 15px;
    font-weight: 600;
    color: #374151;
    transition: transform 0.25s ease;
  }

  .tt-stat-card:hover { transform: translateY(-5px); }

  .tt-stat-num {
    font-size: 50px;
    font-weight: 900;
    color: #ff6b00;
    line-height: 1;
    margin-bottom: 8px;
  }

  /* ── PRODUCT BLOCK ── */
  .tt-product-section {
    background: white;
  }

  .tt-product-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  /* Image gallery */
  .tt-gallery { display: flex; flex-direction: column; gap: 16px; }

  .tt-gallery-main {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: contain;
    background: #f3f4f6;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    cursor: zoom-in;
    padding: 16px;
  }

  .tt-gallery-thumbs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tt-gallery-thumb {
    width: 72px;
    height: 72px;
    object-fit: contain;
    background: #f3f4f6;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
    opacity: 0.7;
    padding: 4px;
  }

  .tt-gallery-thumb:hover,
  .tt-gallery-thumb.active {
    border-color: #ff6b00;
    opacity: 1;
  }

  /* Product details */
  .tt-product-details { display: flex; flex-direction: column; gap: 20px; }

  .tt-product-tag {
    display: inline-block;
    background: #fff7ed;
    color: #c2410c;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid #fed7aa;
  }

  .tt-product-title {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 900;
    line-height: 1.2;
    margin: 0;
    color: #111827;
  }

  .tt-product-desc {
    font-size: 16px;
    color: #4b5563;
    line-height: 1.75;
  }

  .tt-product-desc ul {
    padding-left: 20px;
    margin: 10px 0;
  }

  .tt-product-desc li { margin-bottom: 6px; }

  /* Price row */
  .tt-price-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 16px 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }

  .tt-price-now {
    font-size: 52px;
    font-weight: 900;
    color: #111827;
    line-height: 1;
  }

  .tt-price-was {
    font-size: 22px;
    color: #9ca3af;
    text-decoration: line-through;
  }

  .tt-price-save {
    background: #dcfce7;
    color: #15803d;
    font-size: 13px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 999px;
  }

  .tt-buy-form { display: flex; flex-direction: column; gap: 12px; }

  .tt-buy-form .tt-cta-btn { width: 100%; text-align: center; font-size: 20px; padding: 20px; }

  .tt-buy-note {
    text-align: center;
    font-size: 13px;
    color: #9ca3af;
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ── FEATURE SECTION ── */
  .tt-feature-section { background: #f0f9ff; }

  .tt-feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .tt-feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: white;
    border-radius: 10px;
    font-weight: 600;
    font-size: 15px;
    color: #1f2937;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .tt-feature-item::before {
    content: '✓';
    color: #10b981;
    font-weight: 900;
    font-size: 16px;
    flex-shrink: 0;
  }

  /* ── VALUE STACK ── */
  .tt-value-section {
    background: #111827;
    color: white;
    padding: 70px 20px;
    text-align: center;
  }

  .tt-value-section h2 {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    margin: 0 0 32px;
  }

  .tt-value-table {
    max-width: 620px;
    margin: 0 auto;
    font-size: 18px;
  }

  .tt-value-row {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .tt-value-row:last-child {
    border-bottom: none;
    margin-top: 8px;
    font-size: 22px;
    font-weight: 900;
    color: #ff6b00;
  }

  .tt-value-amount { opacity: 0.65; }
  .tt-value-row:last-child .tt-value-amount { opacity: 1; color: #ff6b00; }

  /* ── GUARANTEE ── */
  .tt-guarantee {
    background: linear-gradient(135deg, #ecfdf5, #d1fae5);
    border: 1px solid #a7f3d0;
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 50px;
  }

  .tt-guarantee-icon { font-size: 48px; }
  .tt-guarantee h3 { font-size: 22px; font-weight: 800; color: #065f46; margin: 0; }
  .tt-guarantee p { color: #047857; font-size: 15px; max-width: 460px; margin: 0; }

  /* ── FAQ ── */
  .tt-faq { max-width: 800px; margin: 0 auto; }

  .tt-faq-item {
    background: white;
    border-radius: 12px;
    padding: 26px 28px;
    margin-bottom: 16px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.05);
  }

  .tt-faq-item h3 { font-size: 17px; font-weight: 800; margin: 0 0 8px; color: #111827; }
  .tt-faq-item p { margin: 0; color: #6b7280; font-size: 15px; }

  /* ── FINAL CTA STRIP ── */
  .tt-final-cta {
    background: linear-gradient(135deg, #0f172a, #1e3a5f);
    color: white;
    text-align: center;
    padding: 70px 20px;
  }

  .tt-final-cta h2 { font-size: clamp(24px, 3vw, 36px); font-weight: 800; margin: 0 0 12px; }
  .tt-final-cta p { opacity: 0.8; margin: 0 0 28px; font-size: 17px; }

  /* ── FOOTER ── */
  .tt-footer {
    background: #0f172a;
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 32px;
    font-size: 13px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .tt-product-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 600px) {
    .tt-gallery-main { aspect-ratio: 3/2; }
    .tt-price-now { font-size: 40px; }
  }
</style>

<div class="tt-wrap">

  {%- comment -%} ═══════════════════ HERO ═══════════════════ {%- endcomment -%}
  <section class="tt-hero">
    <div class="tt-hero-eyebrow">⚡ #1 Therapist Resource Bundle</div>
    <h1>{{ tt.title }}</h1>
    <p>A complete library of 1,100+ professional therapy tools designed to save therapists hours of preparation every week.</p>
    <form action="/cart/add" method="post">
      <input type="hidden" name="id" value="{{ tt_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="return_to" value="/checkout">
      <button type="submit" class="tt-cta-btn">Get Instant Access — {{ tt_variant.price | money }}</button>
    </form>
    <div class="tt-trust-row">
      <span>🔒 Secure Checkout</span>
      <span>⚡ Instant Download</span>
      <span>🛡️ 30-Day Guarantee</span>
      <span>♾️ Lifetime Access</span>
    </div>
  </section>

  {%- comment -%} ═══════════════════ STATS ═══════════════════ {%- endcomment -%}
  <section class="tt-container">
    <h2 class="tt-section-title">What You Get Inside</h2>
    <div class="tt-stat-grid">
      <div class="tt-stat-card"><div class="tt-stat-num">500</div>Professional Therapy Worksheets</div>
      <div class="tt-stat-card"><div class="tt-stat-num">200</div>Guided Session Scripts</div>
      <div class="tt-stat-card"><div class="tt-stat-num">100</div>Clinical Assessment Tools</div>
      <div class="tt-stat-card"><div class="tt-stat-num">100</div>Complete Treatment Plans</div>
      <div class="tt-stat-card"><div class="tt-stat-num">200</div>AI Therapy Prompts</div>
    </div>
  </section>

  {%- comment -%} ═══════════════════ LIVE PRODUCT BLOCK ═══════════════════ {%- endcomment -%}
  <section class="tt-product-section">
    <div class="tt-product-inner">

      {%- comment -%} — Image Gallery — {%- endcomment -%}
      <div class="tt-gallery">
        {% if tt.images.size > 0 %}
          <img
            id="tt-main-img"
            class="tt-gallery-main"
            src="{{ tt.images.first | image_url: width: 800 }}"
            alt="{{ tt.images.first.alt | default: tt.title }}"
          >
          {% if tt.images.size > 1 %}
            <div class="tt-gallery-thumbs">
              {% for img in tt.images %}
                <img
                  class="tt-gallery-thumb{% if forloop.first %} active{% endif %}"
                  src="{{ img | image_url: width: 200 }}"
                  alt="{{ img.alt | default: tt.title }}"
                  data-full="{{ img | image_url: width: 800 }}"
                  onclick="ttSetImg(this)"
                >
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>

      {%- comment -%} — Product Details — {%- endcomment -%}
      <div class="tt-product-details">
        <span class="tt-product-tag">🩺 Professional Bundle</span>

        <h2 class="tt-product-title">{{ tt.title }}</h2>

        <div class="tt-product-desc">{{ tt.description }}</div>

        <div class="tt-price-row">
          <span class="tt-price-now">{{ tt_variant.price | money }}</span>
          {% if tt_variant.compare_at_price > tt_variant.price %}
            <span class="tt-price-was">{{ tt_variant.compare_at_price | money }}</span>
            <span class="tt-price-save">Save {{ tt_variant.compare_at_price | minus: tt_variant.price | money }}</span>
          {% endif %}
        </div>

        <form class="tt-buy-form" action="/cart/add" method="post">
          <input type="hidden" name="id" value="{{ tt_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <input type="hidden" name="return_to" value="/checkout">
          <button type="submit" class="tt-cta-btn">🛒 Buy Now — Instant Download</button>
        </form>

        <div class="tt-buy-note">
          <span>🔒 100% Secure Payment</span>
          <span>⚡ Delivered Instantly</span>
          <span>🛡️ 30-Day Refund</span>
        </div>
      </div>

    </div>
  </section>

  {%- comment -%} ═══════════════════ FEATURES ═══════════════════ {%- endcomment -%}
  <section class="tt-feature-section">
    <div class="tt-container">
      <h2 class="tt-section-title">Covers Every Area of Therapy Practice</h2>
      <div class="tt-feature-grid">
        <div class="tt-feature-item">CBT Worksheets</div>
        <div class="tt-feature-item">DBT Exercises</div>
        <div class="tt-feature-item">Trauma Processing Worksheets</div>
        <div class="tt-feature-item">Anxiety Treatment Tools</div>
        <div class="tt-feature-item">Depression Recovery Plans</div>
        <div class="tt-feature-item">Couples Therapy Exercises</div>
        <div class="tt-feature-item">Client Homework Sheets</div>
        <div class="tt-feature-item">Session Structure Templates</div>
        <div class="tt-feature-item">AI Therapy Prompts</div>
        <div class="tt-feature-item">Clinical Assessments</div>
        <div class="tt-feature-item">Guided Session Scripts</div>
        <div class="tt-feature-item">Complete Treatment Plans</div>
      </div>
    </div>
  </section>

  {%- comment -%} ═══════════════════ VALUE STACK ═══════════════════ {%- endcomment -%}
  <section class="tt-value-section">
    <h2>Total Value Of The Toolkit</h2>
    <div class="tt-value-table">
      <div class="tt-value-row"><span>500 Worksheets</span><span class="tt-value-amount">$297</span></div>
      <div class="tt-value-row"><span>200 Session Scripts</span><span class="tt-value-amount">$197</span></div>
      <div class="tt-value-row"><span>100 Assessments</span><span class="tt-value-amount">$147</span></div>
      <div class="tt-value-row"><span>100 Treatment Plans</span><span class="tt-value-amount">$197</span></div>
      <div class="tt-value-row"><span>200 AI Prompts</span><span class="tt-value-amount">$97</span></div>
      <div class="tt-value-row"><strong>Total Value</strong><span class="tt-value-amount"><strong>$935</strong></span></div>
    </div>
  </section>

  {%- comment -%} ═══════════════════ FINAL CTA ═══════════════════ {%- endcomment -%}
  <section class="tt-final-cta">
    <h2>Ready to Transform Your Practice?</h2>
    <p>Join thousands of therapists who save hours every week with the Ultimate Therapist Toolkit.</p>
    <form action="/cart/add" method="post">
      <input type="hidden" name="id" value="{{ tt_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="return_to" value="/checkout">
      <button type="submit" class="tt-cta-btn">Download The Toolkit — {{ tt_variant.price | money }}</button>
    </form>
    <div class="tt-guarantee" style="max-width:560px; margin: 40px auto 0;">
      <div class="tt-guarantee-icon">🛡️</div>
      <h3>30-Day Money-Back Guarantee</h3>
      <p>Not satisfied? Get a full refund within 30 days — no questions asked.</p>
    </div>
  </section>

  {%- comment -%} ═══════════════════ TESTIMONIALS ═══════════════════ {%- endcomment -%}
  <style>
    .tt-testimonials {
      background: linear-gradient(180deg, #f0f9ff 0%, #ffffff 100%);
      padding: 80px 20px;
    }

    .tt-testimonials-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .tt-testimonials-eyebrow {
      display: flex;
      justify-content: center;
      margin-bottom: 14px;
    }

    .tt-testimonials-eyebrow span {
      background: #e0f2fe;
      color: #0369a1;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 18px;
      border-radius: 999px;
      border: 1px solid #bae6fd;
    }

    .tt-testimonials-title {
      text-align: center;
      font-size: clamp(24px, 3vw, 36px);
      font-weight: 900;
      color: #0f172a;
      margin: 0 0 8px;
    }

    .tt-testimonials-sub {
      text-align: center;
      color: #64748b;
      font-size: 16px;
      margin: 0 0 52px;
    }

    .tt-reviews-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .tt-review-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 28px 24px;
      box-shadow: 0 4px 20px rgba(15, 23, 42, 0.07);
      border: 1px solid #e2e8f0;
      display: flex;
      flex-direction: column;
      gap: 14px;
      position: relative;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .tt-review-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
    }

    .tt-review-quote {
      position: absolute;
      top: 20px;
      right: 22px;
      font-size: 52px;
      line-height: 1;
      color: #e0f2fe;
      font-family: Georgia, serif;
      pointer-events: none;
      user-select: none;
    }

    .tt-review-stars {
      display: flex;
      gap: 3px;
    }

    .tt-review-stars span {
      color: #f59e0b;
      font-size: 16px;
    }

    .tt-review-text {
      font-size: 14px;
      line-height: 1.7;
      color: #334155;
      flex: 1;
      font-style: italic;
    }

    .tt-review-author {
      display: flex;
      align-items: center;
      gap: 12px;
      border-top: 1px solid #f1f5f9;
      padding-top: 14px;
      margin-top: auto;
    }

    .tt-review-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      font-size: 15px;
      font-weight: 800;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      letter-spacing: -0.5px;
    }

    .tt-review-info { flex: 1; min-width: 0; }

    .tt-review-name {
      font-size: 14px;
      font-weight: 800;
      color: #0f172a;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tt-review-title {
      font-size: 12px;
      color: #64748b;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tt-verified {
      font-size: 11px;
      font-weight: 700;
      color: #0ea5e9;
      display: flex;
      align-items: center;
      gap: 4px;
      margin-top: 4px;
    }

    /* Accent colors per card */
    .tt-av-1  { background: linear-gradient(135deg, #0ea5e9, #0369a1); }
    .tt-av-2  { background: linear-gradient(135deg, #14b8a6, #0f766e); }
    .tt-av-3  { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
    .tt-av-4  { background: linear-gradient(135deg, #f97316, #c2410c); }
    .tt-av-5  { background: linear-gradient(135deg, #ec4899, #be185d); }
    .tt-av-6  { background: linear-gradient(135deg, #10b981, #047857); }
    .tt-av-7  { background: linear-gradient(135deg, #f59e0b, #b45309); }
    .tt-av-8  { background: linear-gradient(135deg, #6366f1, #4338ca); }
    .tt-av-9  { background: linear-gradient(135deg, #0ea5e9, #0c4a6e); }
    .tt-av-10 { background: linear-gradient(135deg, #14b8a6, #134e4a); }
    .tt-av-11 { background: linear-gradient(135deg, #f43f5e, #be123c); }
    .tt-av-12 { background: linear-gradient(135deg, #a855f7, #7e22ce); }

    /* Responsive grid */
    @media (max-width: 1100px) {
      .tt-reviews-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 768px) {
      .tt-reviews-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .tt-reviews-grid { grid-template-columns: 1fr; }
    }
  </style>

  <section class="tt-testimonials">
