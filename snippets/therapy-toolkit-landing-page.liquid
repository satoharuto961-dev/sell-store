<script>
  function ttSetImg(thumb) {
    document.getElementById('tt-main-img').src = thumb.dataset.full;
    document.querySelectorAll('.tt-gallery-thumb').forEach(function(t) { t.classList.remove('active'); });
    thumb.classList.add('active');
  }
</script>
