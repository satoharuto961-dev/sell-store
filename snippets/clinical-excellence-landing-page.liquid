{% comment %}
  Clinical Excellence & Innovation Landing Page Snippet
  Targeting: Advanced Practice Nurses, Physician Assistants, Healthcare Administrators, and Researchers.
{% endcomment %}

{% assign bundle_price = 19.99 %}
{% assign individual_price = 125.00 %}
{% assign savings = individual_price | minus: bundle_price %}

{%- capture checkout_url -%}
/cart/lehnes-pharmacotherapeutics-for-advanced-practice-nurses-and-physician-assistants:1,measurement-of-nursing-outcomes-2nd-edition-volume-2-client-outcomes-and-quality-of-care:1,machine-learning-and-ai-for-healthcare-big-data-for-improved-health-outcomes:1,the-clinical-application-of-outcomes-assessment:1,working-with-attachment-trauma-clinical-application-of-the-adult-attachment-projective-picture-system:1
{%- endcapture -%}

<style>
  :root {
    --clinical-primary: #1e3a8a; /* Deep Navy */
    --clinical-accent: #0d9488; /* Medical Teal */
    --clinical-bg: #f8fafc;
    --clinical-card-bg: #ffffff;
    --clinical-text: #0f172a;
    --clinical-muted: #64748b;
  }

  .clinical-page {
    font-family: 'Inter', -apple-system, sans-serif;
    background-color: var(--clinical-bg);
    color: var(--clinical-text);
    line-height: 1.6;
    padding-bottom: 120px;
  }

  .clinical-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero Section */
  .clinical-hero {
    padding: 80px 0 60px;
    text-align: center;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
    color: white;
    margin-bottom: 60px;
    border-radius: 0 0 40px 40px;
  }

  .clinical-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .clinical-hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto 32px;
  }

  /* Content Grid */
  .clinical-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 32px;
    margin-top: 40px;
  }

  .clinical-card {
    background: var(--clinical-card-bg);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s;
    border: 1px solid #e2e8f0;
  }

  .clinical-card:hover {
    transform: translateY(-4px);
  }

  .clinical-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--clinical-primary);
  }

  .clinical-card p {
    color: var(--clinical-muted);
    font-size: 0.95rem;
  }

  /* Featured Book Style */
  .book-showcase {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 40px;
    background: white;
    border-radius: 24px;
    padding: 40px;
    margin-bottom: 40px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    align-items: center;
  }

  .book-cover {
    width: 100%;
    aspect-ratio: 2/3;
    background: #e2e8f0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #94a3b8;
    overflow: hidden;
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }

  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Pricing Footer */
  .sticky-footer {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 800px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(30, 58, 138, 0.1);
    border-radius: 24px;
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    z-index: 1000;
  }

  .price-info h4 {
    margin: 0;
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--clinical-muted);
    letter-spacing: 0.05em;
  }

  .price-info .amount {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--clinical-primary);
  }

  .price-info .original {
    text-decoration: line-through;
    color: var(--clinical-muted);
    font-size: 1rem;
    margin-left: 8px;
  }

  .checkout-btn {
    background: var(--clinical-primary);
    color: white;
    padding: 14px 32px;
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .checkout-btn:hover {
    background: #1e40af;
  }

  @media (max-width: 768px) {
    .book-showcase {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .book-cover {
      max-width: 180px;
      margin: 0 auto;
    }
    .sticky-footer {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

<div class="clinical-page">
  <section class="clinical-hero">
    <div class="clinical-container">
      <h1>Clinical Excellence & Innovation</h1>
      <p>The definitive digital collection for advanced healthcare practitioners, nursing leaders, and clinical researchers.</p>
    </div>
  </section>

  <section class="clinical-container">
    <!-- Featured Item 1 -->
    <div class="book-showcase">
      <div class="book-cover">
        <img src="https://cdn.shopify.com/s/files/1/0846/5467/0772/products/lehnes-pharmacotherapeutics-for-advanced-practice-nurses-and-physician-assistants.jpg?v=1708465467" alt="Lehne's Pharmacotherapeutics">
      </div>
      <div>
        <span style="color: var(--clinical-accent); font-weight: 700; font-size: 0.85rem; text-transform: uppercase;">Core Curriculum</span>
        <h3>Lehne's Pharmacotherapeutics for APNs and PAs</h3>
        <p>A comprehensive clinical resource that bridges the gap between basic pharmacology and clinical application. Essential for providers managing complex medication regimens in primary and acute care settings.</p>
      </div>
    </div>

    <!-- Featured Item 2 -->
    <div class="book-showcase">
      <div class="book-cover">
        <img src="https://cdn.shopify.com/s/files/1/0846/5467/0772/products/measurement-of-nursing-outcomes-2nd-edition-volume-2-client-outcomes-and-quality-of-care.jpg?v=1708465467" alt="Measurement of Nursing Outcomes">
      </div>
      <div>
        <span style="color: var(--clinical-accent); font-weight: 700; font-size: 0.85rem; text-transform: uppercase;">Quality Improvement</span>
        <h3>Measurement of Nursing Outcomes, 2nd Edition</h3>
        <p>Master the tools and frameworks needed to measure client outcomes and the quality of nursing care. An indispensable guide for clinical nurse specialists and nurse administrators focused on evidence-based practice.</p>
      </div>
    </div>

    <div class="clinical-grid">
      <div class="clinical-card">
        <h3>Healthcare AI & Machine Learning</h3>
        <p>Big Data for Improved Health Outcomes. Explore how artificial intelligence is transforming diagnostics, patient tracking, and surgical precision.</p>
      </div>
      <div class="clinical-card">
        <h3>The Clinical Application of Outcomes Assessment</h3>
        <p>Practical strategies for integrating outcome measures into routine clinical practice to drive patient-centered care and institutional accountability.</p>
      </div>
      <div class="clinical-card">
        <h3>Working with Attachment Trauma</h3>
        <p>Clinical application of the Adult Attachment Projective Picture System. A deep dive into modern trauma assessment and therapeutic intervention.</p>
      </div>
    </div>
  </section>

  <div class="sticky-footer">
    <div class="price-info">
      <h4>Full Professional Library</h4>
      <div class="amount">
        $19.99 <span class="original">$125.00</span>
      </div>
    </div>
    <a href="{{ checkout_url }}" class="checkout-btn">Get the Bundle</a>
  </div>
</div>
