{% comment %}
  4-Book Trauma & Emotional Intelligence Bundle Landing Page
  Template: page.4-book-bundle.liquid
{% endcomment %}

{% assign book1 = all_products['emotional-intelligence-2-0'] %}
{% assign book2 = all_products['the-boy-who-was-raised-as-a-dog-and-other-stories-from-a-child-psychiatrists-notebook-what-traumatized-children-can-teach-us-about-loss-love-and-healing'] %}
{% assign book3 = all_products['waking-the-tiger-healing-trauma'] %}
{% assign book4 = all_products['the-body-keeps-the-score-brain-mind-and-body-in-the-healing-of-trauma'] %}

<style>
  /* ── GLOBALS & RESET ── */
  .announce-bar, .site-header { display: none !important; }
  .tt-wrap * { box-sizing: border-box; }
  .tt-wrap {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #1e293b;
    line-height: 1.6;
    background: #f8fafc;
    overflow-x: hidden;
  }
  
  /* ── TYPOGRAPHY & UTILS ── */
  .tt-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; width: 100%; }
  .tt-section { padding: 90px 0; }
  .tt-section-bg-white { background: #ffffff; }
  .tt-section-bg-dark { background: #0f172a; color: white; }
  .tt-text-center { text-align: center; }
  
  .tt-h2 {
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    color: inherit;
  }
  
  .tt-p-lead {
    font-size: clamp(18px, 2vw, 22px);
    color: #475569;
    max-width: 720px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }
  .tt-section-bg-dark .tt-p-lead { color: #94a3b8; }
  
  /* ── BUTTONS ── */
  .tt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: #ff6b00;
    color: white !important;
    font-size: 20px;
    font-weight: 800;
    padding: 20px 48px;
    border-radius: 99px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 25px -5px rgba(255, 107, 0, 0.4);
    line-height: 1;
    width: auto;
  }
  .tt-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -10px rgba(255, 107, 0, 0.5);
  }
  .tt-btn-full { width: 100%; }
  .tt-btn:disabled { opacity: 0.7; cursor: not-allowed; }
  
  .tt-btn-subtext {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #64748b;
    margin-top: 12px;
    font-weight: 500;
  }
  .tt-section-bg-dark .tt-btn-subtext { color: #64748b; }

  /* ── HERO SECTION ── */
  .tt-hero {
    position: relative;
    background: linear-gradient(145deg, #020617 0%, #0f172a 100%);
    color: white;
    padding: 120px 0 100px;
    text-align: center;
    overflow: hidden;
  }
  
  /* Background glow effect */
  .tt-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 1000px;
    background: radial-gradient(circle, rgba(239, 68, 68, 0.15) 0%, rgba(255,255,255,0) 70%);
    pointer-events: none;
  }

  .tt-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 8px 20px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 600;
    color: #e2e8f0;
    margin-bottom: 32px;
  }
  .tt-hero-badge span { color: #ef4444; }

  .tt-hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 900px;
    margin: 0 auto 24px;
    background: linear-gradient(to right, #ffffff, #e2e8f0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tt-hero p.tt-subtitle {
    font-size: clamp(18px, 2.5vw, 24px);
    color: #94a3b8;
    max-width: 760px;
    margin: 0 auto 48px;
    line-height: 1.5;
  }

  /* ── SOCIAL PROOF BAR ── */
  .tt-proof-bar {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 32px 0;
  }
  .tt-proof-grid {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 32px;
  }
  .tt-proof-stat { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .tt-proof-num { font-size: 36px; font-weight: 900; color: #0f172a; line-height: 1; }
  .tt-proof-label { font-size: 14px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
  .tt-proof-stars { color: #f59e0b; font-size: 20px; letter-spacing: 2px; }

  /* ── WHAT'S INSIDE (Books) ── */
  .tt-inventory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }
  .tt-inv-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    text-align: center;
    align-items: center;
  }
  .tt-inv-img-wrap {
    width: 100%;
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    background: #fff;
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
  }
  .tt-inv-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 2px 4px 8px rgba(0,0,0,0.1);
  }
  .tt-inv-title { font-size: 20px; font-weight: 800; color: #0f172a; margin: 0 0 8px; }
  .tt-inv-desc { color: #475569; font-size: 15px; margin: 0; line-height: 1.5; }

  /* ── PRODUCT SHOWCASE ── */
  .tt-showcase { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  
  /* Images */
  .tt-gallery { display: flex; flex-direction: column; gap: 16px; }
  .tt-gallery-main {
    width: 100%;
    aspect-ratio: 1/1;
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    padding: 24px;
    border: 1px solid #e2e8f0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-gap: 20px;
    align-items: center;
    justify-items: center;
  }
  .tt-gallery-main img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    box-shadow: 2px 4px 12px rgba(0,0,0,0.15);
    border-radius: 4px;
  }

  /* Details */
  .tt-showcase-content { display: flex; flex-direction: column; gap: 24px; }
  .tt-tag {
    display: inline-flex;
    background: #fef2f2;
    color: #ef4444;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .tt-showcase-title { font-size: clamp(28px, 4vw, 40px); font-weight: 900; line-height: 1.1; margin: 0; }
  
  .tt-features-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
  .tt-features-list li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    font-size: 16px;
    color: #475569;
  }
  .tt-features-list .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #fee2e2;
    color: #ef4444;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 14px;
    margin-top: 2px;
  }
  .tt-feat-title { font-weight: 700; color: #0f172a; display: block; margin-bottom: 2px; }

  /* Price Block */
  .tt-price-block {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
    margin-top: 16px;
  }
  .tt-price-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .tt-price-now { font-size: 48px; font-weight: 900; color: #0f172a; line-height: 1; }
  .tt-price-was { font-size: 24px; color: #94a3b8; text-decoration: line-through; }
  .tt-price-save {
    background: #fef2f2;
    color: #ef4444;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 800;
  }

  /* ── VALUE STACK ── */
  .tt-val-container { max-width: 800px; margin: 0 auto; }
  .tt-val-box {
    background: white;
    border-radius: 24px;
    padding: 48px;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
  }
  .tt-val-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: 18px;
    color: #334155;
  }
  .tt-val-row strong { color: #0f172a; font-weight: 700; }
  .tt-val-row:last-of-type { border-bottom: none; }
  .tt-val-total {
    background: #f8fafc;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 24px;
  }
  .tt-val-total-label { font-size: 24px; font-weight: 800; color: #0f172a; }
  .tt-val-total-price { font-size: 36px; font-weight: 900; color: #ef4444; text-decoration: line-through; margin-right: 16px; }
  .tt-val-bundle-price { font-size: 36px; font-weight: 900; color: #16a34a; }
  .tt-val-prices { display: flex; align-items: center; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .tt-showcase { grid-template-columns: 1fr; gap: 48px; }
  }
  @media (max-width: 768px) {
    .tt-hero { padding: 80px 0 60px; }
  }
  @media (max-width: 600px) {
    .tt-val-box { padding: 32px 20px; }
    .tt-val-row { font-size: 15px; }
    .tt-val-total { flex-direction: column; gap: 12px; }
    .tt-price-row { flex-wrap: wrap; }
    .tt-val-prices { flex-direction: column; gap: 8px; }
    .tt-val-total-price { margin-right: 0; }
  }
</style>

<div class="tt-wrap">

  {%- comment -%} ═══════════════════ HERO ═══════════════════ {%- endcomment -%}
  <section class="tt-hero">
    <div class="tt-container">
      <div class="tt-hero-badge">
        <span>★</span> The Ultimate Trauma & Emotional Intelligence Collection
      </div>
      
      <h1>Master the Mind-Body Connection</h1>
      <p class="tt-subtitle">Get the four definitive bestselling books on trauma, healing, and emotional mastery bundled together for an unbeatable price.</p>
      
      <button class="tt-btn add-bundle-to-cart">
        Get The Bundle Now — $29.00
      </button>  
      <span class="tt-btn-subtext">30-day money back guarantee</span>
    </div>
  </section>

  {%- comment -%} ═══════════════════ SOCIAL PROOF BAR ═══════════════════ {%- endcomment -%}
  <div class="tt-proof-bar">
    <div class="tt-container">
      <div class="tt-proof-grid">
        <div class="tt-proof-stat">
          <div class="tt-proof-stars">★★★★★</div>
          <div class="tt-proof-label">4.9/5 Average Rating</div>
        </div>
        <div class="tt-proof-stat">
          <div class="tt-proof-num">5M+</div>
          <div class="tt-proof-label">Copies Sold Worldwide</div>
        </div>
        <div class="tt-proof-stat">
          <div class="tt-proof-num">#1</div>
          <div class="tt-proof-label">Bestselling Psychology Books</div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ═══════════════════ THE BOOKS (Inventory) ═══════════════════ {%- endcomment -%}
  <section class="tt-section tt-section-bg-white">
    <div class="tt-container">
      <div class="tt-text-center">
        <h2 class="tt-h2">What's Included in the Bundle</h2>
        <p class="tt-p-lead">Four transformative masterworks on understanding trauma, regulating the nervous system, and cultivating profound emotional intelligence.</p>
      </div>

      <div class="tt-inventory-grid">
        <!-- Book 1 -->
        <div class="tt-inv-card">
          <div class="tt-inv-img-wrap">
            {% if book1.featured_image %}
              <img src="{{ book1.featured_image | img_url: '400x' }}" alt="{{ book1.title | escape }}" class="tt-inv-img" />
            {% endif %}
          </div>
          <h3 class="tt-inv-title">{{ book1.title | default: "Emotional Intelligence 2.0" }}</h3>
          <p class="tt-inv-desc">{{ book1.description | default: "A step-by-step program for increasing your emotional intelligence using the four core EQ skills." | strip_html | truncatewords: 20 }}</p>
        </div>
        <!-- Book 2 -->
        <div class="tt-inv-card">
          <div class="tt-inv-img-wrap">
            {% if book2.featured_image %}
              <img src="{{ book2.featured_image | img_url: '400x' }}" alt="{{ book2.title | escape }}" class="tt-inv-img" />
            {% endif %}
          </div>
          <h3 class="tt-inv-title">{{ book2.title | default: "The Boy Who Was Raised as a Dog" }}</h3>
          <p class="tt-inv-desc">{{ book2.description | default: "What traumatized children can teach us about loss, love, and healing from a child psychiatrist's notebook." | strip_html | truncatewords: 20 }}</p>
        </div>
        <!-- Book 3 -->
        <div class="tt-inv-card">
          <div class="tt-inv-img-wrap">
             {% if book3.featured_image %}
              <img src="{{ book3.featured_image | img_url: '400x' }}" alt="{{ book3.title | escape }}" class="tt-inv-img" />
            {% endif %}
          </div>
          <h3 class="tt-inv-title">{{ book3.title | default: "Waking the Tiger" }}</h3>
          <p class="tt-inv-desc">{{ book3.description | default: "The innate capacity to transform overwhelming experiences and heal trauma." | strip_html | truncatewords: 20 }}</p>
        </div>
        <!-- Book 4 -->
        <div class="tt-inv-card">
          <div class="tt-inv-img-wrap">
            {% if book4.featured_image %}
              <img src="{{ book4.featured_image | img_url: '400x' }}" alt="{{ book4.title | escape }}" class="tt-inv-img" />
            {% endif %}
          </div>
          <h3 class="tt-inv-title">{{ book4.title | default: "The Body Keeps the Score" }}</h3>
          <p class="tt-inv-desc">{{ book4.description | default: "Brain, mind, and body in the healing of trauma." | strip_html | truncatewords: 20 }}</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ═══════════════════ PRODUCT SHOWCASE ═══════════════════ {%- endcomment -%}
  <section class="tt-section" id="purchase">
    <div class="tt-container">
      <div class="tt-showcase">
        
        <!-- Gallery -->
        <div class="tt-gallery">
          <div class="tt-gallery-main">
            {% if book1.featured_image %}<img src="{{ book1.featured_image | img_url: '600x' }}" alt="{{ book1.title | escape }}">{% endif %}
            {% if book2.featured_image %}<img src="{{ book2.featured_image | img_url: '600x' }}" alt="{{ book2.title | escape }}" style="margin-top:20px;">{% endif %}
            {% if book3.featured_image %}<img src="{{ book3.featured_image | img_url: '600x' }}" alt="{{ book3.title | escape }}" style="margin-top:-20px;">{% endif %}
            {% if book4.featured_image %}<img src="{{ book4.featured_image | img_url: '600x' }}" alt="{{ book4.title | escape }}">{% endif %}
          </div>
        </div>

        <!-- Content -->
        <div class="tt-showcase-content">
          <div class="tt-tag">Special Bundle Offer</div>
          <h2 class="tt-showcase-title">The Foundation Library</h2>
          <p style="color:#475569; font-size:16px; margin:0 0 16px;">Equip yourself with the fundamental texts on emotional healing and psychological resilience.</p>
          
          <ul class="tt-features-list">
            <li>
               <div class="icon">✓</div>
               <div><span class="tt-feat-title">4 Bestselling Books</span>Delivered straight to you.</div>
            </li>
            <li>
               <div class="icon">✓</div>
               <div><span class="tt-feat-title">Complete Framework</span>From understanding the neurological impact of trauma to actively increasing emotional intelligence.</div>
            </li>
            <li>
               <div class="icon">✓</div>
               <div><span class="tt-feat-title">Massive Savings</span>Get all four books for significantly less than buying them individually.</div>
            </li>
          </ul>

          <div class="tt-price-block">
            <div class="tt-price-row">
              <span class="tt-price-now">$29.00</span>
              <span class="tt-price-was">
                {% assign total_compare = 0 %}
                {% if book1 %}{% assign total_compare = total_compare | plus: book1.price %}{% endif %}
                {% if book2 %}{% assign total_compare = total_compare | plus: book2.price %}{% endif %}
                {% if book3 %}{% assign total_compare = total_compare | plus: book3.price %}{% endif %}
                {% if book4 %}{% assign total_compare = total_compare | plus: book4.price %}{% endif %}
                {% if total_compare > 0 %}
                   {{ total_compare | money }}
                {% else %}
                   $79.96
                {% endif %}
              </span>
              <span class="tt-price-save">Save Over 60%</span>
            </div>

            <button class="tt-btn tt-btn-full add-bundle-to-cart">
              Add Bundle to Cart
            </button>
            <span class="tt-btn-subtext">Secure Checkout &bull; 30-day money back guarantee</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} ═══════════════════ VALUE STACK ═══════════════════ {%- endcomment -%}
  <section class="tt-section" style="background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);">
    <div class="tt-container">
      <div class="tt-val-container">
        <div class="tt-text-center">
          <h2 class="tt-h2">The Bundle Advantage</h2>
          <p class="tt-p-lead">Why buy individual books when you can get the entire collection for nearly half the price?</p>
        </div>

        <div class="tt-val-box">
          <div class="tt-val-row">
            <span>{{ book4.title | default: "The Body Keeps the Score" }} (Retail)</span>
            <strong>{{ book4.price | money | default: "$19.99" }}</strong>
          </div>
          <div class="tt-val-row">
            <span>{{ book1.title | default: "Emotional Intelligence 2.0" }} (Retail)</span>
            <strong>{{ book1.price | money | default: "$19.99" }}</strong>
          </div>
          <div class="tt-val-row">
            <span>{{ book2.title | default: "The Boy Who Was Raised as a Dog" }} (Retail)</span>
            <strong>{{ book2.price | money | default: "$19.99" }}</strong>
          </div>
          <div class="tt-val-row">
            <span>{{ book3.title | default: "Waking the Tiger" }} (Retail)</span>
            <strong>{{ book3.price | money | default: "$19.99" }}</strong>
          </div>
          
          <div class="tt-val-total">
            <span class="tt-val-total-label">Total Retail Value</span>
            <div class="tt-val-prices">
              <span class="tt-val-total-price">
                {% if total_compare > 0 %}
                   {{ total_compare | money }}
                {% else %}
                   $79.96
                {% endif %}
              </span>
              <span class="tt-val-bundle-price">Only $29.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const bundleButtons = document.querySelectorAll('.add-bundle-to-cart');
    
    // Grab the first available variant ID for each of the 4 valid products
    const itemsToAdd = [];
    
    {% if book1.first_available_variant %}
       itemsToAdd.push({ id: {{ book1.first_available_variant.id }}, quantity: 1 });
    {% endif %}
    {% if book2.first_available_variant %}
       itemsToAdd.push({ id: {{ book2.first_available_variant.id }}, quantity: 1 });
    {% endif %}
    {% if book3.first_available_variant %}
       itemsToAdd.push({ id: {{ book3.first_available_variant.id }}, quantity: 1 });
    {% endif %}
    {% if book4.first_available_variant %}
       itemsToAdd.push({ id: {{ book4.first_available_variant.id }}, quantity: 1 });
    {% endif %}

    bundleButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        
        if(itemsToAdd.length === 0) {
            alert("Sorry, these items are currently unavailable. Please ensure products are published.");
            return;
        }

        // Disable button to prevent double-clicks
        const originalText = this.innerText;
        this.innerText = 'Adding to Cart...';
        this.disabled = true;

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ items: itemsToAdd })
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Network response was not ok');
          }
          return response.json();
        })
        .then(data => {
          // Redirect straight to checkout for highest conversion
          window.location.href = '/checkout';
        })
        .catch(error => {
          console.error('Error adding bundle to cart:', error);
          alert('There was a problem adding the bundle to your cart. Please try again.');
          
          this.innerText = originalText;
          this.disabled = false;
        });
      });
    });
  });
</script>
