{% comment %}
  =============================================================================
  HOMEPAGE PRODUCT GRID — All Books with Add to Cart
  =============================================================================
{% endcomment %}

<style>
  /* ── Announcement Bar ── */
  .announce-bar {
    background: #0f172a;
    color: #fff;
    padding: 10px 0;
    overflow: hidden;
    position: relative;
    width: 100%;
  }
  .announce-track {
    display: flex;
    gap: 80px;
    width: max-content;
    animation: marquee 28s linear infinite;
    white-space: nowrap;
  }
  .announce-bar:hover .announce-track { animation-play-state: paused; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .announce-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .announce-item .tag {
    background: #f59e0b;
    color: #0f172a;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.7rem;
    font-weight: 900;
  }
  .announce-dot {
    color: #f59e0b;
    font-size: 1.2rem;
    line-height: 1;
  }

  /* ── Page Shell ── */
  .shop-page {
    background: #f8fafc;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ── Hero Banner ── */
  .shop-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f3460 100%);
    padding: 56px 24px 48px;
    text-align: center;
    color: #fff;
  }
  .shop-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }
  .shop-hero h1 span { color: #f59e0b; }
  .shop-hero p {
    font-size: 1.1rem;
    color: #94a3b8;
    max-width: 580px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .hero-offers {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 0;
  }
  .hero-offer-pill {
    background: rgba(245,158,11,0.15);
    border: 1.5px solid #f59e0b;
    color: #fcd34d;
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-offer-pill em { color: #fff; font-style: normal; }

  /* ── Grid ── */
  .shop-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 24px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 1200px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px)  { .product-grid { grid-template-columns: 1fr; } }

  /* ── Card ── */
  .book-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(15,23,42,0.07);
    transition: transform 0.35s cubic-bezier(0.19,1,0.22,1),
                box-shadow 0.35s cubic-bezier(0.19,1,0.22,1);
    display: flex;
    flex-direction: column;
  }
  .book-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(15,23,42,0.16);
  }
  .book-card__img-wrap {
    position: relative;
    width: 100%;
    padding-top: 140%; /* portrait ratio */
    overflow: hidden;
    background: #f1f5f9;
  }
  .book-card__img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .book-card:hover .book-card__img-wrap img { transform: scale(1.05); }
  .book-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #0f172a;
    color: #f59e0b;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .book-card__body {
    padding: 20px 20px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .book-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.35;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
  .book-card__stars {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 12px;
  }
  .book-card__stars .stars-svg { color: #f59e0b; font-size: 0.75rem; letter-spacing: 1px; }
  .book-card__stars .review-count { font-size: 0.73rem; color: #94a3b8; }
  .book-card__price {
    font-size: 1.1rem;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 16px;
    margin-top: auto;
  }
  .book-card__price .compare { text-decoration: line-through; color: #94a3b8; font-weight: 400; font-size: 0.85rem; margin-left: 6px; }

  /* ── Add to Cart Button ── */
  .btn-atc {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    text-decoration: none;
  }
  .btn-atc:hover { background: #1e293b; transform: scale(1.02); }
  .btn-atc:active { transform: scale(0.98); }
  .btn-atc svg { width: 16px; height: 16px; flex-shrink: 0; }
  .btn-atc.added {
    background: #059669;
  }

  /* ── Empty state ── */
  .no-products {
    text-align: center;
    padding: 80px 24px;
    color: #64748b;
    font-size: 1.1rem;
  }
</style>

<div class="shop-page">

  <!-- ── Hero ── -->
  <div class="shop-hero">
    <h1>Build Your <span>Library.</span></h1>
    <p>Curated psychology & self-improvement books. Grab more, save more — exclusive bundles just for you.</p>
    <div class="hero-offers">
      <div class="hero-offer-pill">🎁 Buy <em>1</em> → Get <em>2 Free</em></div>
      <div class="hero-offer-pill">🎁 Buy <em>2</em> → Get <em>5 Free</em></div>
      <div class="hero-offer-pill">🎁 Buy <em>3</em> → Get <em>12 Free</em></div>
    </div>
  </div>

  <!-- ── Product Grid ── -->
  <div class="shop-container">
    <p class="section-label">All Books — {{ collections.all.products_count }} titles</p>

    {% if collections.all.products.size > 0 %}
      <div class="product-grid">
        {% for product in collections.all.products limit: 100 %}
          {% assign variant = product.first_available_variant | default: product.variants.first %}
          <div class="book-card">

            <!-- Image -->
            <a href="{{ product.url }}" class="book-card__img-wrap">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | img_url: '600x900', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#e2e8f0;color:#94a3b8;font-size:0.8rem;">No image</div>
              {% endif %}
              <span class="book-card__badge">Book Bundle</span>
            </a>

            <!-- Body -->
            <div class="book-card__body">
              <a href="{{ product.url }}" style="text-decoration:none;">
                <h2 class="book-card__title">{{ product.title }}</h2>
              </a>

              <!-- Stars -->
              <div class="book-card__stars">
                <span class="stars-svg">★★★★★</span>
                <span class="review-count">({{ product.metafields.reviews.rating_count | default: '4.9' }})</span>
              </div>

              <!-- Price -->
              <div class="book-card__price">
                {{ variant.price | money }}
                {% if variant.compare_at_price > variant.price %}
                  <span class="compare">{{ variant.compare_at_price | money }}</span>
                {% endif %}
              </div>

              <!-- Add to Cart -->
              {% if variant.available %}
                <form action="/cart/add" method="post" class="atc-form" data-product-id="{{ product.id }}">
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="btn-atc">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    Add to Cart
                  </button>
                </form>
              {% else %}
                <button class="btn-atc" disabled style="background:#94a3b8;cursor:not-allowed;">Sold Out</button>
              {% endif %}

            </div>
          </div>
        {% endfor %}
      </div>

    {% else %}
      <div class="no-products">
        <p>No products found. Add some products to your store to see them here.</p>
      </div>
    {% endif %}
  </div>

</div>

<script>
  // AJAX Add to Cart — intercept forms and use fetch API
  document.querySelectorAll('.atc-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('.btn-atc');
      var originalText = btn.innerHTML;
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Adding...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: form.querySelector('[name="id"]').value, quantity: 1 })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        btn.classList.add('added');
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Added!';
        // Update cart count if your theme has one
        fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
          var counters = document.querySelectorAll('[data-cart-count], .cart-count, .cart__count');
          counters.forEach(function(el){ el.textContent = cart.item_count; });
        });
        setTimeout(function() {
          btn.classList.remove('added');
          btn.innerHTML = originalText;
          btn.disabled = false;
        }, 2500);
      })
      .catch(function() {
        btn.innerHTML = originalText;
        btn.disabled = false;
        window.location = '/cart';
      });
    });
  });
</script>
