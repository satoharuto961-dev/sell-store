<style>
  :root {
    --bg-main: #ffffff;
    --text-dark: #0f172a;
    --text-muted: #64748b;
    --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --card-shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .gallery-wrapper {
    background-color: var(--bg-main);
    padding: 60px 0 120px;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .gallery-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .gallery-intro {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 80px;
  }

  .gallery-intro h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--text-dark);
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -0.04em;
  }

  .gallery-intro p {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Bento Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 320px;
    gap: 24px;
  }

  .gallery-card {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .gallery-card:hover {
    transform: translateY(-8px) scale(0.98);
    box-shadow: var(--card-shadow-hover);
  }

  /* Overlay for legibility */
  .gallery-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.4) 60%, rgba(15, 23, 42, 0.1) 100%);
    z-index: 1;
    transition: opacity 0.4s ease;
  }

  .gallery-card:hover::after {
    background: linear-gradient(to top, rgba(15, 23, 42, 1) 10%, rgba(15, 23, 42, 0.5) 70%, rgba(15, 23, 42, 0.2) 100%);
  }

  .card-content {
    position: relative;
    z-index: 2;
    transition: transform 0.5s ease;
  }

  .card-tag {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #38bdf8; /* Medical light blue accent */
    margin-bottom: 8px;
    display: block;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .card-title {
    font-size: 1.85rem;
    font-weight: 900;
    color: white;
    margin-bottom: 12px;
    line-height: 1.1;
    text-shadow: 0 4px 8px rgba(0,0,0,0.5);
  }

  .card-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 90%;
    margin: 0;
    opacity: 0;
    height: 0;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .gallery-card:hover .card-desc {
    opacity: 1;
    height: auto;
    margin-top: 8px;
  }

  /* Card Layouts */
  .card-large { grid-column: span 2; grid-row: span 2; }
  .card-wide  { grid-column: span 2; }
  .card-tall  { grid-row: span 2; }

  @media (max-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .card-large, .card-wide, .card-tall { grid-column: span 1; grid-row: span 1; }
    .gallery-card { height: 320px; }
  }

  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-intro h1 { font-size: 2.5rem; }
  }
</style>

