    .sl-hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(239,246,255,0.8); backdrop-filter: blur(10px); border: 1px solid #bfdbfe; border-radius: 999px; padding: 6px 18px; font-size: 0.85rem; font-weight: 700; color: var(--brand); margin-bottom: 24px; }
    .sl-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: var(--text-primary); line-height: 1.1; letter-spacing: -1.2px; max-width: 900px; margin: 0 auto 24px; }
    .sl-hero-sub { font-size: clamp(1.05rem, 2.5vw, 1.25rem); color: var(--text-secondary); max-width: 750px; margin: 0 auto 40px; line-height: 1.7; font-weight: 500; }
    .sl-hero-actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-bottom: 24px; }
    .sl-btn-primary { display: inline-flex; align-items: center; gap: 10px; background: linear-gradient(135deg, var(--brand), var(--accent)); color: #fff; border: none; border-radius: 14px; padding: 18px 40px; font-size: 1.1rem; font-weight: 900; cursor: pointer; text-decoration: none; box-shadow: 0 10px 30px rgba(37,99,235,0.35); transition: all 0.25s; position: relative; overflow: hidden; }
    .sl-btn-primary:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 16px 40px rgba(37,99,235,0.45); }
    
    .sl-hero-img { margin-top: 50px; }
    .sl-hero-img img { max-width: 600px; width: 100%; border-radius: 16px; box-shadow: 0 32px 90px rgba(0,0,0,0.15); border: 1.5px solid rgba(255,255,255,0.6); }
    
    /* Sections */
    .sl-section { padding: 90px 24px; }
    .sl-section-inner { max-width: 1100px; margin: 0 auto; }
    .sl-label { font-size: 0.85rem; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--brand); margin-bottom: 16px; display: inline-block; background: var(--brand-light); padding: 6px 16px; border-radius: 999px; }
    .sl-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; color: var(--text-primary); letter-spacing: -1px; line-height: 1.15; margin-bottom: 20px; }
    
    /* Grid */
    .sl-grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 50px; }
    .sl-card { background: #fff; border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.3s; }
    .sl-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); }
    .sl-card img { width: 100%; display: block; border-bottom: 1px solid var(--border); }
    .sl-card-body { padding: 24px; }
    .sl-card-title { font-weight: 800; font-size: 1.1rem; margin-bottom: 8px; color: var(--text-primary); }
    .sl-card-text { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; }
    
    /* Features */
    .sl-features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
    .sl-feature-item { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid var(--border); border-radius: 20px; padding: 28px; box-shadow: 0 4px 16px rgba(0,0,0,0.03); }
    .sl-check { width: 36px; height: 36px; background: var(--brand); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 900; flex-shrink: 0; }
    .sl-feature-text { font-size: 1.05rem; font-weight: 800; color: var(--text-primary); margin-bottom: 4px; }
    .sl-feature-sub { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; }
    
    /* Gallery */
    .sl-gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 40px; }
    .sl-gallery img { width: 100%; border-radius: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); transition: transform 0.3s ease; }
    .sl-gallery img:hover { transform: scale(1.02); }

    @media (max-width: 768px) {
      .sl-hero { padding: 80px 20px 60px; }
      .sl-sticky-cta { flex-direction: column; text-align: center; gap: 12px; }
    }
  </style>
</head>
