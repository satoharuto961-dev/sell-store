  .fc-divider-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, #78350f, transparent); }
  .fc-divider-icon { color: #d97706; font-size: 1.25rem; }

  /* ---- Button ---- */
  .fc-btn-container { text-align: center; margin: 2rem 0; }
