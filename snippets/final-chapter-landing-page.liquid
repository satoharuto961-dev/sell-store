  .fc-btn-subtext {
    display: block; font-size: 0.875rem;
    color: #57534e; margin-top: 1rem; font-weight: 600;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  /* ---- Thesis ---- */
  .fc-thesis {
    background: #1c1408;
    border-radius: 4px; padding: 4rem 3.5rem;
    margin-top: -3rem; position: relative; z-index: 20;
    border: 1px solid #78350f;
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.9);
  }
  .fc-thesis p { font-size: 1.2rem; color: #a16207; }
  .fc-thesis strong { color: #fef3c7; }

  /* ---- Book Cards ---- */
  .fc-breakdown-card {
    display: grid; grid-template-columns: 170px 1fr;
    gap: 3rem; background: #1c1408;
    padding: 3rem; border-radius: 4px; margin-bottom: 1.5rem;
    align-items: center; border: 1px solid #292116;
    transition: all 0.3s ease;
  }
  .fc-breakdown-card:hover {
    transform: translateY(-3px);
    border-color: #78350f;
    box-shadow: 0 20px 40px -10px rgba(180,83,9,0.15);
  }
  .fc-breakdown-img {
    width: 100%; max-width: 170px; display: block;
    border-radius: 3px; box-shadow: -10px 10px 20px rgba(0,0,0,0.7);
    filter: sepia(0.08);
    margin: 0 auto;
  }
  .fc-book-tag {
    display: inline-block; padding: 0.2rem 0.875rem;
    background: transparent; color: #d97706;
    border-radius: 0; font-weight: 700;
    font-size: 0.75rem; margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.12em;
    border: 1px solid #78350f;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  .fc-checklist { list-style: none; padding: 0; margin: 1.5rem 0 0; }
  .fc-checklist li {
    position: relative; padding-left: 1.75rem;
    margin-bottom: 0.625rem; font-size: 1.05rem; color: #a16207;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  .fc-checklist li::before {
    content: "◆"; position: absolute; left: 0;
    color: #d97706; font-size: 0.6rem; top: 0.45rem;
  }

  /* ---- Social Proof ---- */
  .fc-reviews {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem; margin-top: 2.5rem;
  }
  .fc-review-card {
    background: #1c1408; padding: 2rem; border-radius: 4px;
    border: 1px solid #292116;
  }
  .fc-stars { color: #d97706; font-size: 1.1rem; margin-bottom: 0.75rem; }
  .fc-review-text { font-style: italic; font-size: 1.05rem; margin-bottom: 1.25rem; color: #d6d3d1; line-height: 1.7; font-family: Georgia, serif; }
  .fc-review-author { font-weight: 700; color: #fef3c7; font-size: 0.875rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }

  /* ---- Pricing ---- */
  .fc-pricing-hero {
    background: #1c1408;
    border: 1px solid #78350f; border-radius: 4px;
    padding: 4rem 2rem; text-align: center; margin: 4rem 0;
    box-shadow: 0 0 80px rgba(180,83,9,0.08), inset 0 1px 0 rgba(253,243,199,0.05);
  }
  .fc-pricing-hero h2 { color: #fef3c7; }
  .fc-pricing-hero p { color: #78350f; }
  .fc-price-block { margin: 2rem 0; }
  .fc-price-current { font-size: 4.5rem; font-weight: 900; color: #fef3c7; line-height: 1; font-family: Georgia, serif; }
  .fc-price-original { font-size: 1.375rem; color: #44403c; text-decoration: line-through; margin-left: 0.75rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
