    position: relative; overflow: hidden;
  }
  /* Subtle gold shimmer lines */
  .fc-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent, transparent 60px,
      rgba(217,119,6,0.04) 60px, rgba(217,119,6,0.04) 61px
    );
    pointer-events: none;
  }
  .fc-hero::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(180,83,9,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .fc-eyebrow {
    display: inline-block;
    background: transparent; color: #d97706;
    padding: 0.375rem 1.5rem; border-radius: 0;
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    margin-bottom: 2.5rem;
    border: 1px solid #78350f;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    position: relative; z-index: 1;
  }
  .fc-hero-title {
    font-size: 3.75rem; margin-bottom: 1.5rem;
