{% assign bundle_handles = "the-aeneid,palace-walk-the-cairo-trilogy-volume-1,as-i-lay-dying-the-corrected-text,the-island-of-the-day-before,therapeutic-action-an-earnest-plea-for-irony" | split: "," %}

{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}
{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

<style>
  /* =============================================
     THE FINAL CHAPTER — Dark Gold / Antique Amber
     ============================================= */
  .fc-landing-page {
    font-family: Georgia, "Times New Roman", serif;
    color: #292524;
    line-height: 1.7;
    background-color: #0f0d09;
    padding-bottom: 100px;
  }
  .fc-container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
  .fc-section { padding: 4rem 0; }

  h1, h2, h3 { line-height: 1.2; font-weight: 900; font-family: Georgia, serif; color: #fef3c7; }
  h2 { font-size: 2.25rem; margin-bottom: 2rem; text-align: center; }
  h3 { font-size: 1.4rem; margin-bottom: 0.75rem; }
  p { font-size: 1.125rem; color: #92400e; margin-bottom: 1.5rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }

  /* ---- Hero ---- */
  .fc-hero {
    text-align: center;
    padding: 5.5rem 1rem 4.5rem;
    background: radial-gradient(ellipse at top, #1c1408 0%, #0f0d09 70%);
