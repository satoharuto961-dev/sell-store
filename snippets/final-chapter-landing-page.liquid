    display: inline-flex; align-items: center;
    background: transparent; color: #d97706;
    padding: 0.5rem 1.5rem; border-radius: 0;
    font-size: 1rem; font-weight: 800; margin-top: 1.5rem;
    border: 1px solid #78350f;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  /* ---- Trust Icons ---- */
  .fc-trust-icons {
    display: flex; justify-content: center; align-items: center;
    gap: 2rem; margin-top: 2rem; flex-wrap: wrap;
  }
  .fc-trust-icon {
    display: flex; align-items: center; gap: 0.4rem;
    color: #44403c; font-weight: 600; font-size: 0.85rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  /* ---- Sticky Bar ---- */
  .fc-sticky-form { margin: 0; }
  .fc-sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
