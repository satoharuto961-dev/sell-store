{% assign bundle_handles = "gender-power-and-global-social-justice-the-healing-power-of-psychotherapy,addressing-cultural-complexities-in-counseling-and-clinical-practice-an-intersectional-approach,cbt-the-cognitive-behavioural-tsunami-managerialism-politics-and-the-corruptions-of-science,on-theology-and-psychology-the-correspondence-of-c-g-jung-and-adolf-keller-philemon-foundation-series,internships-in-psychology-the-apags-workbook-for-writing-successful-applications-and-finding-the-right-fit" | split: "," %}

{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}
{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

<style>
  /* =============================================
     CULTURAL PSYCHOLOGY — Warm Terracotta / Earth
     ============================================= */
  .cp9-landing-page {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #292524;
    line-height: 1.6;
    background-color: #fdf8f6;
    padding-bottom: 100px;
  }
  .cp9-container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
  .cp9-section { padding: 4rem 0; }

  h1, h2, h3 { line-height: 1.2; font-weight: 900; color: #1c1917; }
  h2 { font-size: 2.25rem; margin-bottom: 2rem; text-align: center; }
  h3 { font-size: 1.5rem; margin-bottom: 0.75rem; }
  p { font-size: 1.125rem; color: #57534e; margin-bottom: 1.5rem; }

  /* ---- Hero ---- */
  .cp9-hero {
    text-align: center;
    padding: 5rem 1rem 4rem;
    background: linear-gradient(160deg, #fff7ed 0%, #fdf8f6 60%);
    border-bottom: 1px solid #fed7aa;
    position: relative; overflow: hidden;
  }
  .cp9-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(234,88,12,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(180,83,9,0.04) 0%, transparent 50%);
    pointer-events: none;
  }
  .cp9-eyebrow {
    display: inline-block;
    background: #fff7ed; color: #c2410c;
    padding: 0.375rem 1.25rem; border-radius: 999px;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 2rem; border: 1px solid #fed7aa;
  }
  .cp9-hero-title {
    font-size: 3.5rem; margin-bottom: 1.5rem;
    letter-spacing: -0.03em; color: #1c1917;
    position: relative; z-index: 1;
  }
  .cp9-hero-title span { color: #ea580c; }
  .cp9-hero-subtitle {
    font-size: 1.375rem; max-width: 760px;
    margin: 0 auto 3.5rem; color: #78716c;
    position: relative; z-index: 1;
  }
  .cp9-books-display {
    display: flex; justify-content: center; align-items: flex-end;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem;
    position: relative; z-index: 1;
  }
  .cp9-book-wrapper {
    width: 140px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 15px 25px rgba(180,83,9,0.15));
  }
  .cp9-book-wrapper:hover {
    transform: translateY(-18px) scale(1.06);
    filter: drop-shadow(0 25px 35px rgba(180,83,9,0.3));
  }
  .cp9-book-cover {
    width: 100%; height: auto; border-radius: 5px;
    box-shadow: -8px 12px 20px rgba(0,0,0,0.18), inset 2px 0 4px rgba(255,255,255,0.5);
  }

  /* ---- Button ---- */
  .cp9-btn-container { text-align: center; margin: 2rem 0; }
  .cp9-btn {
    display: inline-block;
    background: linear-gradient(135deg, #ea580c, #c2410c);
    color: white; font-size: 1.375rem; font-weight: 800;
    padding: 1.25rem 3rem; border-radius: 100px;
    text-decoration: none; transition: all 0.2s ease;
    border: none; cursor: pointer;
    box-shadow: 0 10px 30px -5px rgba(234,88,12,0.4);
  }
  .cp9-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -10px rgba(234,88,12,0.6);
    color: white;
    background: linear-gradient(135deg, #f97316, #ea580c);
  }
  .cp9-btn-subtext {
    display: block; font-size: 0.875rem;
    color: #a8a29e; margin-top: 1rem; font-weight: 600;
  }

  /* ---- Thesis ---- */
  .cp9-thesis {
    background: white;
    border-radius: 24px; padding: 4rem 3rem;
    margin-top: -3rem; position: relative; z-index: 20;
    border: 1px solid #e7e5e4;
    box-shadow: 0 20px 50px -15px rgba(0,0,0,0.08);
  }
  .cp9-thesis p { font-size: 1.2rem; color: #57534e; }
  .cp9-thesis strong { color: #1c1917; }

  /* ---- Book Cards ---- */
  .cp9-breakdown-card {
    display: grid; grid-template-columns: 180px 1fr;
    gap: 3rem; background: white;
    padding: 3rem; border-radius: 20px; margin-bottom: 1.5rem;
    align-items: center; border: 1px solid #e7e5e4;
    transition: all 0.3s ease;
  }
  .cp9-breakdown-card:hover {
    transform: translateY(-4px);
    border-color: #fed7aa;
    box-shadow: 0 20px 40px -10px rgba(234,88,12,0.1);
  }
  .cp9-breakdown-img {
    width: 100%; max-width: 180px; display: block;
    border-radius: 5px; box-shadow: -8px 8px 16px rgba(0,0,0,0.12);
    margin: 0 auto;
  }
  .cp9-book-tag {
    display: inline-block; padding: 0.25rem 1rem;
    background: #fff7ed; color: #c2410c;
    border-radius: 999px; font-weight: 700;
    font-size: 0.8rem; margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    border: 1px solid #fed7aa;
  }
  .cp9-checklist { list-style: none; padding: 0; margin: 1.5rem 0 0; }
  .cp9-checklist li {
    position: relative; padding-left: 1.75rem;
    margin-bottom: 0.625rem; font-size: 1.05rem; color: #57534e;
  }
  .cp9-checklist li::before {
    content: "✓"; position: absolute; left: 0;
    color: #ea580c; font-weight: 900; font-size: 1rem; line-height: 1.4;
  }

  /* ---- Social Proof ---- */
  .cp9-reviews {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem; margin-top: 2.5rem;
  }
  .cp9-review-card {
    background: white; padding: 2rem; border-radius: 16px;
    border: 1px solid #e7e5e4;
  }
  .cp9-stars { color: #f97316; font-size: 1.25rem; margin-bottom: 0.75rem; }
  .cp9-review-text { font-style: italic; font-size: 1.05rem; margin-bottom: 1.25rem; color: #44403c; line-height: 1.65; }
  .cp9-review-author { font-weight: 700; color: #1c1917; font-size: 0.9rem; }

  /* ---- Pricing ---- */
  .cp9-pricing-hero {
    background: linear-gradient(135deg, #1c1917, #292524);
    border-radius: 24px; padding: 4rem 2rem;
    text-align: center; margin: 4rem 0;
    box-shadow: 0 0 60px rgba(234,88,12,0.08);
  }
  .cp9-pricing-hero h2 { color: white; }
  .cp9-pricing-hero p { color: #78716c; }
  .cp9-price-block { margin: 2rem 0; }
  .cp9-price-current { font-size: 4.5rem; font-weight: 900; color: white; line-height: 1; }
  .cp9-price-original { font-size: 1.375rem; color: #44403c; text-decoration: line-through; margin-left: 0.75rem; }
  .cp9-savings-badge {
    display: inline-flex; align-items: center;
    background: #7c2d12; color: #fed7aa;
    padding: 0.5rem 1.5rem; border-radius: 999px;
    font-size: 1rem; font-weight: 800; margin-top: 1.5rem;
    border: 1px solid #9a3412;
  }

  /* ---- Trust Icons ---- */
  .cp9-trust-icons {
    display: flex; justify-content: center; align-items: center;
    gap: 2rem; margin-top: 2rem; flex-wrap: wrap;
  }
  .cp9-trust-icon {
    display: flex; align-items: center; gap: 0.4rem;
    color: #57534e; font-weight: 600; font-size: 0.85rem;
  }

  /* ---- Sticky Bar ---- */
  .cp9-sticky-form { margin: 0; }
  .cp9-sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: white; padding: 0.875rem 1rem;
    box-shadow: 0 -8px 30px rgba(234,88,12,0.12); z-index: 50;
    display: flex; justify-content: center; align-items: center;
    gap: 1.5rem; transform: translateY(100%);
    transition: transform 0.3s ease; border-top: 1px solid #fed7aa;
  }
  .cp9-sticky-bar.visible { transform: translateY(0); }
  .cp9-sticky-title { font-weight: 800; font-size: 1rem; display: none; color: #1c1917; }
  .cp9-sticky-price { font-weight: 900; font-size: 1.5rem; color: #ea580c; }

  @media (min-width: 1024px) { .cp9-sticky-title { display: block; } }
  @media (max-width: 768px) {
    .cp9-hero-title { font-size: 2.5rem; }
    .cp9-hero-subtitle { font-size: 1.125rem; }
    .cp9-thesis { padding: 2rem 1.5rem; margin-top: -2rem; }
    .cp9-breakdown-card { grid-template-columns: 1fr; gap: 1.5rem; text-align: center; padding: 2rem 1.5rem; }
    .cp9-checklist li { text-align: left; }
    .cp9-books-display { gap: 0.5rem; }
    .cp9-book-wrapper { width: 100px; }
  }
</style>

<div class="cp9-landing-page">

  <!-- HERO -->
  <header class="cp9-hero">
    <div class="cp9-container">
      <div class="cp9-eyebrow">The Inclusive Practitioner's Library</div>
      <h1 class="cp9-hero-title">Psychology That Sees <span>The Whole Person</span></h1>
      <p class="cp9-hero-subtitle">5 essential works on cultural identity, social justice, critical theory, and inclusive clinical practice — for the modern, complete therapist.</p>

      <div class="cp9-books-display">
        {% for handle in bundle_handles %}
          {% assign current_product = all_products[handle] %}
          {% if current_product != empty %}
            <div class="cp9-book-wrapper">
              <img src="{{ current_product.featured_image | img_url: '400x' }}" alt="{{ current_product.title }}" class="cp9-book-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="cp9-btn-container">
        <a href="#checkout-section" class="cp9-btn" style="display:inline-block; max-width:420px; padding:1.25rem 2.5rem;">
          Claim The Library →
        </a>
        <span class="cp9-btn-subtext">Save over 30% instantly vs buying individually.</span>
      </div>
    </div>
  </header>

  <!-- THESIS -->
  <div class="cp9-container">
    <div class="cp9-thesis">
      <h2>Why Cultural Competency?</h2>
      <p>Every client enters the therapy room carrying their culture, history, identity, and lived experience. The most effective therapists today aren't just technically skilled — they are <strong>culturally humble, critically aware, and able to hold complexity.</strong></p>
      <p>This library was curated for practitioners and students who want to move beyond standard clinical training: examining how power, gender, spirituality, and systemic injustice intersect with psychological healing. From Jung's dialogue with theology, to a critical deconstruction of CBT's institutional politics, to actionable frameworks for culturally responsive practice.</p>
    </div>
  </div>

  <!-- BOOK BREAKDOWNS -->
  <section class="cp9-section">
    <div class="cp9-container">
      <h2>Inside The Library</h2>

      <!-- Book 1 -->
      {% assign p = all_products['gender-power-and-global-social-justice-the-healing-power-of-psychotherapy'] %}
      {% if p != empty %}
      <div class="cp9-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="cp9-breakdown-img">
        <div>
          <span class="cp9-book-tag">Intersectional Healing</span>
          <h3>Gender, Power, and Global Social Justice</h3>
          <p>A powerful academic and clinical exploration of how gender, power dynamics, and global structural inequalities shape trauma and psychological healing.</p>
          <ul class="cp9-checklist">
            <li>Groundbreaking intersectional frameworks for clinical practice.</li>
            <li>Understanding how patriarchy and global power structures create psychological distress.</li>
            <li>Essential for any clinician working with diverse, marginalized populations.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 2 -->
      {% assign p = all_products['addressing-cultural-complexities-in-counseling-and-clinical-practice-an-intersectional-approach'] %}
      {% if p != empty %}
      <div class="cp9-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="cp9-breakdown-img">
        <div>
          <span class="cp9-book-tag">Cultural Competency</span>
          <h3>Addressing Cultural Complexities in Counseling</h3>
          <p>The definitive textbook on intersectional counseling practice — actionable, research-grounded frameworks for working effectively across race, gender, sexuality, and class.</p>
          <ul class="cp9-checklist">
            <li>Case studies from genuinely diverse client populations.</li>
            <li>Practical intersectional assessment and treatment tools.</li>
            <li>Widely used in accredited counseling training programs.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 3 -->
      {% assign p = all_products['cbt-the-cognitive-behavioural-tsunami-managerialism-politics-and-the-corruptions-of-science'] %}
      {% if p != empty %}
      <div class="cp9-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="cp9-breakdown-img">
        <div>
          <span class="cp9-book-tag">Critical Theory</span>
          <h3>CBT: The Cognitive Behavioural Tsunami</h3>
          <p>A brilliantly argued critique of how CBT became politically and economically dominant in mental health — often at the expense of deeper, more effective therapies.</p>
          <ul class="cp9-checklist">
            <li>Understand the institutional politics behind evidence-based hierarchies.</li>
            <li>A must-read for any practitioner questioning the overcrowded CBT monoculture.</li>
            <li>Strengthen your critical thinking on best practice and clinical autonomy.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 4 -->
      {% assign p = all_products['on-theology-and-psychology-the-correspondence-of-c-g-jung-and-adolf-keller-philemon-foundation-series'] %}
      {% if p != empty %}
      <div class="cp9-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="cp9-breakdown-img">
        <div>
          <span class="cp9-book-tag">Spirituality and Depth Psychology</span>
          <h3>On Theology and Psychology — C.G. Jung</h3>
          <p>A rare and fascinating collection of correspondence between Jung and theologian Adolf Keller — exploring the profound dialogue between spiritual experience and psychological truth.</p>
          <ul class="cp9-checklist">
            <li>Jung's most candid reflections on religion, meaning, and the psyche.</li>
            <li>Essential for practitioners working with spiritual or religious clients.</li>
            <li>A window into depth psychology's complex relationship with faith.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 5 -->
      {% assign p = all_products['internships-in-psychology-the-apags-workbook-for-writing-successful-applications-and-finding-the-right-fit'] %}
      {% if p != empty %}
      <div class="cp9-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="cp9-breakdown-img">
        <div>
          <span class="cp9-book-tag">Graduate Professional Development</span>
          <h3>Internships in Psychology: The APAGS Workbook</h3>
          <p>The official American Psychological Association workbook for psychology graduate students — the complete, practical guide to securing clinical internships and launching a career.</p>
          <ul class="cp9-checklist">
            <li>Step-by-step applications, personal statements, and interview prep.</li>
            <li>How to find the right internship culture and clinical fit for your goals.</li>
            <li>Indispensable for any doctoral student approaching internship match season.</li>
          </ul>
        </div>
      </div>
      {% endif %}

    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="cp9-section" style="background: white; border-top: 1px solid #e7e5e4; border-bottom: 1px solid #e7e5e4;">
    <div class="cp9-container">
      <h2>What Practitioners Are Saying</h2>
      <div class="cp9-reviews">
        <div class="cp9-review-card">
          <div class="cp9-stars">★★★★★</div>
          <p class="cp9-review-text">"The Cultural Complexities textbook and the Gender, Power &amp; Social Justice book together are genuinely transformative for understanding intersectionality in clinical work. Required for my practicum students."</p>
          <p class="cp9-review-author">— Dr. Maria Santos, Graduate Program Director</p>
        </div>
        <div class="cp9-review-card">
          <div class="cp9-stars">★★★★★</div>
          <p class="cp9-review-text">"The CBT Tsunami book finally articulates what I've felt in practice for years. Every therapist should read it — whether they agree or not. Paired with the Jung correspondence, this is a deeply thoughtful library."</p>
          <p class="cp9-review-author">— Alistair C., Psychodynamic Therapist</p>
        </div>
        <div class="cp9-review-card">
          <div class="cp9-stars">★★★★★</div>
          <p class="cp9-review-text">"The APAGS workbook alone saved me weeks of stress during internship season. This entire bundle gave me both the practical tools and the critical framework to become a more rounded clinician."</p>
          <p class="cp9-review-author">— Jasmine T., Doctoral Candidate</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CHECKOUT -->
  <section class="cp9-section" id="checkout-section">
    <div class="cp9-container">
      <div class="cp9-pricing-hero">
        <h2>Expand Your Practice</h2>
        <p>All 5 essential works for the culturally competent practitioner.</p>

        <div class="cp9-price-block">
          <span class="cp9-price-current">{{ bundle_price | money }}</span>
          {% if total_compare_price > bundle_price %}
            <span class="cp9-price-original">{{ total_compare_price | money }}</span>
            <br/>
            <div class="cp9-savings-badge">
              You Save {{ total_compare_price | minus: bundle_price | money }} By Bundling Today
            </div>
          {% endif %}
        </div>

        <div class="cp9-btn-container" style="max-width:500px; margin:2rem auto 0;">
          {% form 'cart', cart %}
            {% for handle in bundle_handles %}
              {% assign current_product = all_products[handle] %}
              {% if current_product != empty %}
                {% assign variant = current_product.first_available_variant %}
                <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
              {% endif %}
            {% endfor %}
            <input type="hidden" name="checkout" value="Checkout" />
            <button type="submit" class="cp9-btn" style="width:100%; max-width:480px;">
              Proceed to Secure Checkout
            </button>
          {% endform %}
        </div>

        <p style="color:#57534e; font-size:0.875rem; margin-top:1.5rem; margin-bottom:0;">
          30-Day Money-Back Guarantee. Encrypted Checkout.
        </p>

        <div class="cp9-trust-icons">
          <div class="cp9-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#ea580c;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            Encrypted Checkout
          </div>
          <div class="cp9-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#ea580c;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Instant Processing
          </div>
          <div class="cp9-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#ea580c;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            30-Day Guarantee
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STICKY BAR -->
  <div class="cp9-sticky-bar" id="cp9-sticky-bar">
    <span class="cp9-sticky-title">The Cultural Psychology Library</span>
    <span class="cp9-sticky-price">{{ bundle_price | money }}</span>
    {% form 'cart', cart, class: 'cp9-sticky-form' %}
      {% for handle in bundle_handles %}
        {% assign current_product = all_products[handle] %}
        {% if current_product != empty %}
          {% assign variant = current_product.first_available_variant %}
          <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
        {% endif %}
      {% endfor %}
      <input type="hidden" name="checkout" value="Checkout" />
      <button type="submit" class="cp9-btn" style="width:auto; padding:0.75rem 1.75rem; font-size:1rem;">
        Buy Now
      </button>
    {% endform %}
  </div>
</div>

<script>
  (function() {
    var bar = document.getElementById('cp9-sticky-bar');
    var checkout = document.getElementById('checkout-section');
    document.querySelectorAll('a[href^="#"]').forEach(function(a) {
      a.addEventListener('click', function(e) {
        var t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
      });
    });
    window.addEventListener('scroll', function() {
      if (bar && checkout) {
        var top = checkout.getBoundingClientRect().top;
        if (window.scrollY > 500 && top > window.innerHeight) {
          bar.classList.add('visible');
        } else { bar.classList.remove('visible'); }
      }
    });
  })();
</script>
