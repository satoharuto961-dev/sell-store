{% assign bundle_handles = "murder-on-the-orient-express-a-hercule-poirot-mystery-the-official-authorized-edition,rebecca,cloud-atlas-a-novel,the-plot-against-america-vintage-international,the-crying-of-lot-49-a-postmodern-classic-witty-satire-of-conspiracy-paranoia-and-american-life-perennial-classics" | split: "," %}

{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}
{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

<style>
  /* =============================================
     MYSTERY & INTRIGUE — Noir Dark Teal / Slate
     ============================================= */
  .mi-landing-page {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #ccfbf1;
    line-height: 1.6;
    background-color: #030f0e;
    padding-bottom: 100px;
  }
  .mi-container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
  .mi-section { padding: 4rem 0; }

  h1, h2, h3 { line-height: 1.2; font-weight: 900; color: #f0fdfa; }
  h2 { font-size: 2.25rem; margin-bottom: 2rem; text-align: center; }
  h3 { font-size: 1.5rem; margin-bottom: 0.75rem; }
  p { font-size: 1.125rem; color: #5eead4; margin-bottom: 1.5rem; }

  /* ---- Hero ---- */
  .mi-hero {
    text-align: center;
    padding: 5rem 1rem 4rem;
    background: radial-gradient(ellipse at top, #042f2e 0%, #030f0e 65%);
    border-bottom: 1px solid #0d3330;
    position: relative; overflow: hidden;
  }
  /* Subtle fog lines */
  .mi-hero::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      135deg,
      transparent, transparent 40px,
      rgba(20,184,166,0.025) 40px, rgba(20,184,166,0.025) 41px
    );
    pointer-events: none;
  }
  .mi-eyebrow {
    display: inline-block;
    background: #0d3330; color: #5eead4;
    padding: 0.375rem 1.25rem; border-radius: 999px;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 2rem; border: 1px solid #134e4a;
  }
  .mi-hero-title {
    font-size: 3.75rem; margin-bottom: 1.5rem;
    letter-spacing: -0.03em; color: #f0fdfa;
    position: relative; z-index: 1;
  }
  .mi-hero-title span { color: #2dd4bf; }
  .mi-hero-subtitle {
    font-size: 1.375rem; max-width: 760px;
    margin: 0 auto 3.5rem; color: #99f6e4;
    position: relative; z-index: 1;
  }
  .mi-books-display {
    display: flex; justify-content: center; align-items: flex-end;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem;
    position: relative; z-index: 1;
  }
  .mi-book-wrapper {
    width: 140px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 20px 30px rgba(20,184,166,0.2));
  }
  .mi-book-wrapper:hover {
    transform: translateY(-20px) scale(1.07) rotate(-1.5deg);
    filter: drop-shadow(0 30px 40px rgba(20,184,166,0.4));
  }
  .mi-book-cover {
    width: 100%; height: auto; border-radius: 5px;
    box-shadow: -10px 15px 25px rgba(0,0,0,0.85), inset 2px 0 4px rgba(255,255,255,0.1);
  }

  /* ---- Button ---- */
  .mi-btn-container { text-align: center; margin: 2rem 0; }
  .mi-btn {
    display: inline-block;
    background: linear-gradient(135deg, #0f766e, #0d9488);
    color: white; font-size: 1.375rem; font-weight: 800;
    padding: 1.25rem 3rem; border-radius: 100px;
    text-decoration: none; transition: all 0.2s ease;
    border: none; cursor: pointer;
    box-shadow: 0 10px 30px -5px rgba(13,148,136,0.45);
  }
  .mi-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -10px rgba(13,148,136,0.65);
    color: white;
    background: linear-gradient(135deg, #14b8a6, #0f766e);
  }
  .mi-btn-subtext {
    display: block; font-size: 0.875rem;
    color: #134e4a; margin-top: 1rem; font-weight: 600;
  }

  /* ---- Thesis ---- */
  .mi-thesis {
    background: #071a19;
    border-radius: 24px; padding: 4rem 3rem;
    margin-top: -3rem; position: relative; z-index: 20;
    border: 1px solid #0d3330;
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.9);
  }
  .mi-thesis p { font-size: 1.2rem; color: #99f6e4; }
  .mi-thesis strong { color: #f0fdfa; }

  /* ---- Book Cards ---- */
  .mi-breakdown-card {
    display: grid; grid-template-columns: 180px 1fr;
    gap: 3rem; background: #071a19;
    padding: 3rem; border-radius: 20px; margin-bottom: 1.5rem;
    align-items: center; border: 1px solid #0d3330;
    transition: all 0.3s ease;
  }
  .mi-breakdown-card:hover {
    transform: translateY(-4px);
    border-color: #134e4a;
    box-shadow: 0 20px 40px -10px rgba(13,148,136,0.2);
  }
  .mi-breakdown-img {
    width: 100%; max-width: 180px; display: block;
    border-radius: 5px; box-shadow: -10px 10px 20px rgba(0,0,0,0.7);
    margin: 0 auto;
  }
  .mi-book-tag {
    display: inline-block; padding: 0.25rem 1rem;
    background: #042f2e; color: #5eead4;
    border-radius: 999px; font-weight: 700;
    font-size: 0.8rem; margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    border: 1px solid #0d3330;
  }
  .mi-checklist { list-style: none; padding: 0; margin: 1.5rem 0 0; }
  .mi-checklist li {
    position: relative; padding-left: 1.75rem;
    margin-bottom: 0.625rem; font-size: 1.05rem; color: #5eead4;
  }
  .mi-checklist li::before {
    content: "›"; position: absolute; left: 0;
    color: #2dd4bf; font-weight: 900; font-size: 1.3rem; line-height: 1.1;
  }

  /* ---- Social Proof ---- */
  .mi-reviews {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem; margin-top: 2.5rem;
  }
  .mi-review-card {
    background: #071a19; padding: 2rem; border-radius: 16px;
    border: 1px solid #0d3330;
  }
  .mi-stars { color: #2dd4bf; font-size: 1.25rem; margin-bottom: 0.75rem; }
  .mi-review-text { font-style: italic; font-size: 1.05rem; margin-bottom: 1.25rem; color: #ccfbf1; line-height: 1.65; }
  .mi-review-author { font-weight: 700; color: #f0fdfa; font-size: 0.9rem; }

  /* ---- Pricing ---- */
  .mi-pricing-hero {
    background: linear-gradient(135deg, #071a19, #030f0e);
    border: 1px solid #0d3330; border-radius: 24px;
    padding: 4rem 2rem; text-align: center; margin: 4rem 0;
    box-shadow: 0 0 60px rgba(13,148,136,0.1);
  }
  .mi-pricing-hero h2 { color: white; }
  .mi-pricing-hero p { color: #134e4a; }
  .mi-price-block { margin: 2rem 0; }
  .mi-price-current { font-size: 4.5rem; font-weight: 900; color: white; line-height: 1; }
  .mi-price-original { font-size: 1.375rem; color: #0d3330; text-decoration: line-through; margin-left: 0.75rem; }
  .mi-savings-badge {
    display: inline-flex; align-items: center;
    background: #0d3330; color: #5eead4;
    padding: 0.5rem 1.5rem; border-radius: 999px;
    font-size: 1rem; font-weight: 800; margin-top: 1.5rem;
    border: 1px solid #134e4a;
  }

  /* ---- Trust Icons ---- */
  .mi-trust-icons {
    display: flex; justify-content: center; align-items: center;
    gap: 2rem; margin-top: 2rem; flex-wrap: wrap;
  }
  .mi-trust-icon {
    display: flex; align-items: center; gap: 0.4rem;
    color: #0d3330; font-weight: 600; font-size: 0.85rem;
  }

  /* ---- Sticky Bar ---- */
  .mi-sticky-form { margin: 0; }
  .mi-sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: #071a19; padding: 0.875rem 1rem;
    box-shadow: 0 -8px 30px rgba(13,148,136,0.2); z-index: 50;
    display: flex; justify-content: center; align-items: center;
    gap: 1.5rem; transform: translateY(100%);
    transition: transform 0.3s ease; border-top: 1px solid #0d3330;
  }
  .mi-sticky-bar.visible { transform: translateY(0); }
  .mi-sticky-title { font-weight: 800; font-size: 1rem; display: none; color: #f0fdfa; }
  .mi-sticky-price { font-weight: 900; font-size: 1.5rem; color: #2dd4bf; }

  @media (min-width: 1024px) { .mi-sticky-title { display: block; } }
  @media (max-width: 768px) {
    .mi-hero-title { font-size: 2.5rem; }
    .mi-hero-subtitle { font-size: 1.125rem; }
    .mi-thesis { padding: 2rem 1.5rem; margin-top: -2rem; }
    .mi-breakdown-card { grid-template-columns: 1fr; gap: 1.5rem; text-align: center; padding: 2rem 1.5rem; }
    .mi-checklist li { text-align: left; }
    .mi-books-display { gap: 0.5rem; }
    .mi-book-wrapper { width: 100px; }
  }
</style>

<div class="mi-landing-page">

  <!-- HERO -->
  <header class="mi-hero">
    <div class="mi-container">
      <div class="mi-eyebrow">The Intelligent Reader's Thrill Collection</div>
      <h1 class="mi-hero-title">You Won't See the <span>Ending</span> Coming</h1>
      <p class="mi-hero-subtitle">5 masterworks of suspense, hidden secrets, and mind-bending narratives — for readers who demand more than a simple whodunit.</p>

      <div class="mi-books-display">
        {% for handle in bundle_handles %}
          {% assign current_product = all_products[handle] %}
          {% if current_product != empty %}
            <div class="mi-book-wrapper">
              <img src="{{ current_product.featured_image | img_url: '400x' }}" alt="{{ current_product.title }}" class="mi-book-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="mi-btn-container">
        <a href="#checkout-section" class="mi-btn" style="display:inline-block; max-width:420px; padding:1.25rem 2.5rem;">
          Claim The Collection →
        </a>
        <span class="mi-btn-subtext">Save over 30% instantly vs buying individually.</span>
      </div>
    </div>
  </header>

  <!-- THESIS -->
  <div class="mi-container">
    <div class="mi-thesis">
      <h2>More Than Just Mysteries</h2>
      <p>The greatest suspense fiction doesn't just trick you with a plot twist. It forces you to question <strong>what you believe about truth, power, reality, and human nature.</strong></p>
      <p>From Christie's perfectly constructed logic puzzles, to du Maurier's psychological fog, to Mitchell's six overlapping realities across centuries — this collection was curated for readers who want their thrillers to leave them thinking long after the last page. These aren't beach reads. They are intelligent, haunting, and absolutely unforgettable.</p>
    </div>
  </div>

  <!-- BOOK BREAKDOWNS -->
  <section class="mi-section">
    <div class="mi-container">
      <h2>Inside The Collection</h2>

      <!-- Book 1: Murder on the Orient Express -->
      {% assign p = all_products['murder-on-the-orient-express-a-hercule-poirot-mystery-the-official-authorized-edition'] %}
      {% if p != empty %}
      <div class="mi-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="mi-breakdown-img">
        <div>
          <span class="mi-book-tag">The Perfect Mystery</span>
          <h3>Murder on the Orient Express</h3>
          <p>Agatha Christie's most iconic and beloved novel — a snowbound train, a dead passenger, twelve suspects, and Hercule Poirot at his brilliant best.</p>
          <ul class="mi-checklist">
            <li>The mystery plot that defined an entire genre.</li>
            <li>One of the most satisfying endings in all of fiction.</li>
            <li>Christie's masterclass in misdirection and logic.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 2: Rebecca -->
      {% assign p = all_products['rebecca'] %}
      {% if p != empty %}
      <div class="mi-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="mi-breakdown-img">
        <div>
          <span class="mi-book-tag">Gothic Psychological Thriller</span>
          <h3>Rebecca</h3>
          <p>Daphne du Maurier's haunting gothic masterpiece — the second Mrs de Winter entering Manderley mansion and the terrifying shadow of Rebecca, who never truly left.</p>
          <ul class="mi-checklist">
            <li>The ultimate exploration of obsession, jealousy, and secrets.</li>
            <li>One of the most atmospheric, fog-drenched novels ever written.</li>
            <li>An opening line — "Last night I dreamt I went to Manderley again" — that never leaves you.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 3: Cloud Atlas -->
      {% assign p = all_products['cloud-atlas-a-novel'] %}
      {% if p != empty %}
      <div class="mi-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="mi-breakdown-img">
        <div>
          <span class="mi-book-tag">Mind-Bending Narrative</span>
          <h3>Cloud Atlas</h3>
          <p>David Mitchell's genre-defying masterwork: six interlocking stories spanning centuries, from the 19th century Pacific to a post-apocalyptic future — a novel about how every soul echoes through time.</p>
          <ul class="mi-checklist">
            <li>The most ambitious structural achievement in modern fiction.</li>
            <li>Six completely distinct voices and genres, flawlessly executed.</li>
            <li>A profound meditation on power, identity, and reincarnation.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 4: The Plot Against America -->
      {% assign p = all_products['the-plot-against-america-vintage-international'] %}
      {% if p != empty %}
      <div class="mi-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="mi-breakdown-img">
        <div>
          <span class="mi-book-tag">Alternate History Thriller</span>
          <h3>The Plot Against America</h3>
          <p>Philip Roth's chilling alternate history: what if Charles Lindbergh — an American hero and Nazi sympathizer — had won the 1940 presidential election? Fascism at home, seen through a child's eyes.</p>
          <ul class="mi-checklist">
            <li>One of the most urgent and prescient political novels ever written.</li>
            <li>Roth at his most visceral and terrifying.</li>
            <li>Feels less like fiction and more like a warning with every passing year.</li>
          </ul>
        </div>
      </div>
      {% endif %}

      <!-- Book 5: The Crying of Lot 49 -->
      {% assign p = all_products['the-crying-of-lot-49-a-postmodern-classic-witty-satire-of-conspiracy-paranoia-and-american-life-perennial-classics'] %}
      {% if p != empty %}
      <div class="mi-breakdown-card">
        <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" class="mi-breakdown-img">
        <div>
          <span class="mi-book-tag">Conspiracy Paranoia</span>
          <h3>The Crying of Lot 49</h3>
          <p>Thomas Pynchon's hilarious, paranoid, postmodern spiral — a woman unravels a mysterious underground postal conspiracy that may or may not exist, and may or may not involve everyone.</p>
          <ul class="mi-checklist">
            <li>The perfect entry point into Pynchon's universe — compact and electric.</li>
            <li>A brilliant satire of American consumerism and information overload.</li>
            <li>You'll be questioning what's real long after the final page.</li>
          </ul>
        </div>
      </div>
      {% endif %}

    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="mi-section" style="background:#030f0e; border-top:1px solid #071a19;">
    <div class="mi-container">
      <h2>What Readers Are Saying</h2>
      <div class="mi-reviews">
        <div class="mi-review-card">
          <div class="mi-stars">★★★★★</div>
          <p class="mi-review-text">"Rebecca destroyed me. Cloud Atlas blew my mind. The Plot Against America haunted me for weeks. This is not a collection — it's an experience."</p>
          <p class="mi-review-author">— Sandra L., Librarian</p>
        </div>
        <div class="mi-review-card">
          <div class="mi-stars">★★★★★</div>
          <p class="mi-review-text">"Christie invented the modern mystery genre with Orient Express and this bundle proves how far that tradition has evolved. Five completely different types of suspense in one perfect package."</p>
          <p class="mi-review-author">— Tom R., Crime Fiction Author</p>
        </div>
        <div class="mi-review-card">
          <div class="mi-stars">★★★★★</div>
          <p class="mi-review-text">"The Crying of Lot 49 is the funniest, most paranoid, most brilliant short novel I've ever read. Pairing it with The Plot Against America was inspired. These five books are a total journey."</p>
          <p class="mi-review-author">— Elena V., Publisher</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CHECKOUT -->
  <section class="mi-section" id="checkout-section">
    <div class="mi-container">
      <div class="mi-pricing-hero">
        <h2>Uncover The Truth</h2>
        <p>All 5 masterworks of mystery and intrigue.</p>

        <div class="mi-price-block">
          <span class="mi-price-current">{{ bundle_price | money }}</span>
          {% if total_compare_price > bundle_price %}
            <span class="mi-price-original">{{ total_compare_price | money }}</span>
            <br/>
            <div class="mi-savings-badge">
              You Save {{ total_compare_price | minus: bundle_price | money }} By Bundling Today
            </div>
          {% endif %}
        </div>

        <div class="mi-btn-container" style="max-width:500px; margin:2rem auto 0;">
          {% form 'cart', cart %}
            {% for handle in bundle_handles %}
              {% assign current_product = all_products[handle] %}
              {% if current_product != empty %}
                {% assign variant = current_product.first_available_variant %}
                <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
              {% endif %}
            {% endfor %}
            <input type="hidden" name="checkout" value="Checkout" />
            <button type="submit" class="mi-btn" style="width:100%; max-width:480px;">
              Proceed to Secure Checkout
            </button>
          {% endform %}
        </div>

        <p style="color:#0d3330; font-size:0.875rem; margin-top:1.5rem; margin-bottom:0;">
          30-Day Money-Back Guarantee. Encrypted Checkout.
        </p>

        <div class="mi-trust-icons">
          <div class="mi-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#0f766e;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            Encrypted Checkout
          </div>
          <div class="mi-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#0f766e;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Instant Processing
          </div>
          <div class="mi-trust-icon">
            <svg style="width:1.125rem;height:1.125rem;color:#0f766e;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            30-Day Guarantee
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STICKY BAR -->
  <div class="mi-sticky-bar" id="mi-sticky-bar">
    <span class="mi-sticky-title">The Mystery & Intrigue Collection</span>
    <span class="mi-sticky-price">{{ bundle_price | money }}</span>
    {% form 'cart', cart, class: 'mi-sticky-form' %}
      {% for handle in bundle_handles %}
        {% assign current_product = all_products[handle] %}
        {% if current_product != empty %}
          {% assign variant = current_product.first_available_variant %}
          <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
        {% endif %}
      {% endfor %}
      <input type="hidden" name="checkout" value="Checkout" />
      <button type="submit" class="mi-btn" style="width:auto; padding:0.75rem 1.75rem; font-size:1rem;">
        Buy Now
      </button>
    {% endform %}
  </div>
</div>

<script>
  (function() {
    var bar = document.getElementById('mi-sticky-bar');
    var checkout = document.getElementById('checkout-section');
    document.querySelectorAll('a[href^="#"]').forEach(function(a) {
      a.addEventListener('click', function(e) {
        var t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
      });
    });
    window.addEventListener('scroll', function() {
      if (bar && checkout) {
        var top = checkout.getBoundingClientRect().top;
        if (window.scrollY > 500 && top > window.innerHeight) {
          bar.classList.add('visible');
        } else {
          bar.classList.remove('visible');
        }
      }
    });
  })();
</script>
