{% assign bundle_handles = "the-cbt-flip-chart-an-evidence-based-psychoeducational-tool-for-anxiety,attachment-focused-emdr-healing-relational-trauma,motivational-interviewing-in-health-care-helping-patients-change-behavior-applications-of-motivational-interviewing-series,play-therapy-4th-edition,practical-counselling-and-helping-skills" | split: "," %}

{% comment %} 
  Override bundle_price to exactly $19.99 (1999 in cents) 
  But keep calculating the total_compare_price to show accurate savings
{% endcomment %}
{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}

{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

<style>
  /* Base Styles */
  .cp-landing-page {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #111827;
    line-height: 1.6;
    background-color: #f8fafc; /* Crisp, clinical slate-gray */
    padding-bottom: 100px;
  }
  
  .cp-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .cp-section {
    padding: 4rem 0;
  }

  /* Typography */
  h1, h2, h3 { line-height: 1.2; font-weight: 800; color: #0f172a; }
  h2 { font-size: 2.25rem; margin-bottom: 2rem; text-align: center; }
  h3 { font-size: 1.5rem; margin-bottom: 1rem; }
  p { font-size: 1.125rem; color: #475569; margin-bottom: 1.5rem; }

  /* Hero Section */
  .cp-hero {
    text-align: center;
    padding: 5rem 1rem 3rem;
    background: linear-gradient(135deg, #e0f2fe 0%, #ffffff 100%); /* Clinical, trustworthy blue */
    border-bottom: 1px solid #e2e8f0;
  }
  
  .cp-hero-title {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    color: #0c4a6e; /* Deep navy */
  }
  
  .cp-hero-subtitle {
    font-size: 1.5rem;
    max-width: 800px;
    margin: 0 auto 3rem;
    color: #334155;
  }
  
  .cp-books-display {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .cp-book-wrapper {
    width: 150px;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .cp-book-wrapper:hover {
    transform: translateY(-15px) scale(1.05);
    z-index: 10;
  }
  
  .cp-book-cover {
    width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: -12px 12px 24px rgba(0,0,0,0.15), inset 2px 0 5px rgba(255,255,255,0.4);
  }

  /* Button Styles */
  .cp-btn-container {
    text-align: center;
    margin: 2rem 0;
  }

  .cp-btn {
    display: inline-block;
    background: linear-gradient(to right, #0284c7, #0369a1); /* Trustworthy medical blue */
    color: white;
    font-size: 1.5rem;
    font-weight: 800;
    padding: 1.25rem 3rem;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 25px -5px rgba(2, 132, 199, 0.4);
    width: 100%;
    max-width: 500px;
  }
  
  .cp-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -10px rgba(2, 132, 199, 0.6);
    color: white;
  }

  .cp-btn-subtext {
    display: block;
    font-size: 0.875rem;
    color: #64748b;
    margin-top: 1rem;
    font-weight: 600;
  }

  /* The Problem/Solution Block */
  .cp-thesis {
    background: white;
    border-radius: 24px;
    padding: 4rem 3rem;
    margin-top: -3rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05);
    position: relative;
    z-index: 20;
  }

  .cp-thesis p {
    font-size: 1.25rem;
  }

  /* Book Breakdown Grid */
  .cp-breakdown-card {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 3rem;
    background: white;
    padding: 3rem;
    border-radius: 24px;
    margin-bottom: 2rem;
    align-items: center;
    border: 1px solid #f1f5f9;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cp-breakdown-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
  }

  .cp-breakdown-img {
    width: 100%;
    max-width: 200px;
    margin: 0 auto;
    display: block;
    border-radius: 6px;
    box-shadow: -8px 8px 16px rgba(0,0,0,0.12);
  }

  .cp-book-tag {
    display: inline-block;
    padding: 0.25rem 1rem;
    background: #e0f2fe;
    color: #0369a1;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cp-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0 0;
  }

  .cp-checklist li {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    color: #475569;
  }

  .cp-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #0284c7;
    font-weight: 900;
  }

  /* Pricing Section */
  .cp-pricing-hero {
    background: #0f172a;
    color: white;
    border-radius: 24px;
    padding: 4rem 2rem;
    text-align: center;
    margin: 4rem 0;
  }

  .cp-pricing-hero h2 { color: white; }
  .cp-pricing-hero p { color: #94a3b8; }

  .cp-price-block { margin: 2rem 0; }
  .cp-price-current { font-size: 4rem; font-weight: 900; color: white; line-height: 1; }
  .cp-price-original { font-size: 1.5rem; color: #64748b; text-decoration: line-through; margin-left: 1rem; }
  
  .cp-savings-badge {
    display: inline-flex;
    align-items: center;
    background: #0284c7;
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 800;
    margin-top: 1.5rem;
  }

  /* Social Proof */
  .cp-reviews {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .cp-review-card {
    background: white;
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
  }

  .cp-stars { color: #fbbf24; font-size: 1.25rem; margin-bottom: 1rem; }
  .cp-review-text { font-style: italic; font-size: 1.125rem; margin-bottom: 1.5rem; color: #334155; }
  .cp-review-author { font-weight: 700; color: #0f172a; }

  /* Trust Icons */
  .cp-trust-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  
  .cp-trust-icon {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #94a3b8;
    font-weight: 600;
    font-size: 0.875rem;
  }

  /* Sticky Footer */
  .cp-sticky-form { margin: 0; }
  .cp-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: white;
    padding: 1rem;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.1);
    z-index: 50;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    border-top: 1px solid #e2e8f0;
  }
  
  .cp-sticky-bar.visible { transform: translateY(0); }
  .cp-sticky-title { font-weight: 800; font-size: 1.125rem; display: none; color: #0f172a; }
  .cp-sticky-price { font-weight: 900; font-size: 1.5rem; color: #0284c7; }

  @media (min-width: 1024px) {
    .cp-sticky-title { display: block; }
  }

  @media (max-width: 768px) {
    .cp-hero-title { font-size: 2.5rem; }
    .cp-hero-subtitle { font-size: 1.25rem; }
    .cp-thesis { padding: 2rem 1.5rem; margin-top: -2rem; }
    .cp-breakdown-card { grid-template-columns: 1fr; gap: 2rem; text-align: center; padding: 2rem 1.5rem; }
    .cp-checklist li { text-align: left; }
    .cp-books-display { gap: 0.5rem; }
    .cp-book-wrapper { width: 110px; }
  }
</style>

<div class="cp-landing-page">
  
  <!-- HERO HEADLINE -->
  <header class="cp-hero">
    <div class="cp-container">
      <h1 class="cp-hero-title">The Clinical Practitioner's Library</h1>
      <p class="cp-hero-subtitle">5 definitive, evidence-based guides to master CBT, EMDR, Play Therapy, and Motivational Interviewing.</p>
      
      <div class="cp-books-display">
        {% for handle in bundle_handles %}
          {% assign current_product = all_products[handle] %}
          {% if current_product != empty %}
            <div class="cp-book-wrapper">
              <img src="{{ current_product.featured_image | img_url: '400x' }}" alt="{{ current_product.title }}" class="cp-book-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      <div class="cp-btn-container">
        <a href="#checkout-section" class="cp-btn" style="display:inline-block; max-width:400px; padding:1.25rem 2rem;">Claim The Toolkit →</a>
        <span class="cp-btn-subtext">Save over 30% instantly vs buying individually.</span>
      </div>
    </div>
  </header>

  <!-- THE THESIS -->
  <div class="cp-container">
    <div class="cp-thesis">
      <h2>Why These 5 Modalities?</h2>
      <p>Theory isn't enough when you're in the room with a client. The most effective therapists and counselors rely on a foundation of <strong>actionable, evidence-based tools that drive immediate behavioral change.</strong></p>
      <p>There are thousands of textbooks published every year, but true clinical growth comes from mastering the methodologies that actually heal trauma and rewrite cognition. We curated this exact stack of 5 books to give you the ultimate practitioner's toolkit: from structured CBT interventions and relational EMDR, to mastering the nuances of play therapy and motivational interviewing.</p>
    </div>
  </div>

  <!-- BOOK BREAKDOWNS -->
  <section class="cp-section">
    <div class="cp-container">
      <h2>What's Inside The Arsenal</h2>
      
      <!-- Book 1 -->
      <div class="cp-breakdown-card">
        <img src="{{ all_products['the-cbt-flip-chart-an-evidence-based-psychoeducational-tool-for-anxiety'].featured_image | img_url: '400x' }}" alt="The CBT Flip Chart" class="cp-breakdown-img">
        <div>
          <span class="cp-book-tag">Cognitive Frameworks</span>
          <h3>The CBT Flip Chart</h3>
          <p>An indispensable, evidence-based psychoeducational tool for treating Anxiety, Depression, Stress, Insomnia, and PTSD.</p>
          <ul class="cp-checklist">
            <li>Interactive visual aids to explain CBT to clients.</li>
            <li>Ready-to-use exercises for immediate clinical application.</li>
            <li>Streamline session structure and homework assignments.</li>
          </ul>
        </div>
      </div>

      <!-- Book 2 -->
      <div class="cp-breakdown-card">
        <img src="{{ all_products['attachment-focused-emdr-healing-relational-trauma'].featured_image | img_url: '400x' }}" alt="Attachment-Focused EMDR" class="cp-breakdown-img">
        <div>
          <span class="cp-book-tag">Trauma Recovery</span>
          <h3>Attachment-Focused EMDR</h3>
          <p>The definitive guide to adapting EMDR therapy to safely and effectively heal profound relational and attachment trauma.</p>
          <ul class="cp-checklist">
            <li>Advanced protocols for complex developmental trauma.</li>
            <li>Techniques for resource instillation and dual attention.</li>
            <li>Navigate client dissociation and blocking effectively.</li>
          </ul>
        </div>
      </div>

      <!-- Book 3 -->
      <div class="cp-breakdown-card">
        <img src="{{ all_products['motivational-interviewing-in-health-care-helping-patients-change-behavior-applications-of-motivational-interviewing-series'].featured_image | img_url: '400x' }}" alt="Motivational Interviewing in Health Care" class="cp-breakdown-img">
        <div>
          <span class="cp-book-tag">Behavioral Change</span>
          <h3>Motivational Interviewing in Health Care</h3>
          <p>The core text on how to help ambivalent patients find the internal motivation to change destructive, ingrained behaviors.</p>
          <ul class="cp-checklist">
            <li>Master the "OARS" foundational communication skills.</li>
            <li>Roll with resistance instead of fighting it.</li>
            <li>Elicit "change talk" naturally and effectively.</li>
          </ul>
        </div>
      </div>

      <!-- Book 4 -->
      <div class="cp-breakdown-card">
        <img src="{{ all_products['play-therapy-4th-edition'].featured_image | img_url: '400x' }}" alt="Play Therapy 4th Edition" class="cp-breakdown-img">
        <div>
          <span class="cp-book-tag">Child Psychology</span>
          <h3>Play Therapy: The Art of the Relationship</h3>
          <p>The 4th Edition of Garry Landreth's authoritative text on understanding and utilizing child-centered play therapy.</p>
          <ul class="cp-checklist">
            <li>Establish secure therapeutic boundaries with children.</li>
            <li>Facilitate emotional expression through toys and play.</li>
            <li>Essential readings for pediatric counseling.</li>
          </ul>
        </div>
      </div>

      <!-- Book 5 -->
      <div class="cp-breakdown-card">
        <img src="{{ all_products['practical-counselling-and-helping-skills'].featured_image | img_url: '400x' }}" alt="Practical Counselling and Helping Skills" class="cp-breakdown-img">
        <div>
          <span class="cp-book-tag">Core Competency</span>
          <h3>Practical Counselling and Helping Skills</h3>
          <p>The foundational textbook detailing the absolute required skills, ethics, and practices every counselor must possess.</p>
          <ul class="cp-checklist">
            <li>Master active listening and empathetic responding.</li>
            <li>Build the core therapeutic alliance.</li>
            <li>Navigate complex ethical boundaries with confidence.</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="cp-section" style="background: white; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">
    <div class="cp-container">
      <h2>Success Leaves Clues</h2>
      <div class="cp-reviews">
        <div class="cp-review-card">
          <div class="cp-stars">★★★★★</div>
          <p class="cp-review-text">"As a program director, I consider this specific bundle to be mandatory reading for all our incoming graduate clinicians. The CBT Flip Chart alone is worth the price."</p>
          <p class="cp-review-author">— Dr. James M., Clinical Director</p>
        </div>
        <div class="cp-review-card">
          <div class="cp-stars">★★★★★</div>
          <p class="cp-review-text">"Parnell's work on Attachment-Focused EMDR combined with Motivational Interviewing gives you an incredibly versatile toolkit for complex trauma clients."</p>
          <p class="cp-review-author">— Sarah T., Licensed Therapist</p>
        </div>
        <div class="cp-review-card">
          <div class="cp-stars">★★★★★</div>
          <p class="cp-review-text">"If you're building a private practice or finishing your licensure hours, these 5 books will bridge the gap between classroom theory and real-world therapy."</p>
          <p class="cp-review-author">— Emily C., LMHC</p>
        </div>
      </div>
    </div>
  </section>

  <!-- THE OFFER (CHECKOUT) -->
  <section class="cp-section" id="checkout-section">
    <div class="cp-container">
      <div class="cp-pricing-hero">
        <h2>Your Toolkit Awaits</h2>
        <p>Get all 5 essential clinical texts today.</p>
        
        <div class="cp-price-block">
          <span class="cp-price-current">{{ bundle_price | money }}</span>
          {% if total_compare_price > bundle_price %}
             <span class="cp-price-original">{{ total_compare_price | money }}</span>
             <br/>
             <div class="cp-savings-badge">
               You Save {{ total_compare_price | minus: bundle_price | money }} By Bundling Today
             </div>
          {% endif %}
        </div>
        
        <div class="cp-btn-container" style="max-width: 500px; margin: 0 auto;">
          {% form 'cart', cart %}
            {% for handle in bundle_handles %}
              {% assign current_product = all_products[handle] %}
              {% if current_product != empty %}
                {% assign variant = current_product.first_available_variant %}
                <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
              {% endif %}
            {% endfor %}
            <input type="hidden" name="checkout" value="Checkout" />
            <button type="submit" class="cp-btn">
              Proceed to Secure Checkout
            </button>
          {% endform %}
        </div>
        
        <p style="color: #94a3b8; font-size: 0.875rem; margin-top: 1.5rem;">
          Includes 30-Day Money-Back Guarantee.
        </p>

        <div class="cp-trust-icons">
          <div class="cp-trust-icon" style="color:#94a3b8;">
            <svg style="width:1.25rem;height:1.25rem;color:#10b981;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            Encrypted Checkout
          </div>
          <div class="cp-trust-icon" style="color:#94a3b8;">
            <svg style="width:1.25rem;height:1.25rem;color:#fbbf24;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Instant Processing
          </div>
          <div class="cp-trust-icon" style="color:#94a3b8;">
            <svg style="width:1.25rem;height:1.25rem;color:#3b82f6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            30-Day Guarantee
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STICKY BOTTOM BAR -->
  <div class="cp-sticky-bar" id="sticky-bar">
    <span class="cp-sticky-title">The Clinical Practitioner's Library</span>
    <span class="cp-sticky-price">{{ bundle_price | money }}</span>
    {% form 'cart', cart, class: 'cp-sticky-form' %}
      {% for handle in bundle_handles %}
        {% assign current_product = all_products[handle] %}
        {% if current_product != empty %}
          {% assign variant = current_product.first_available_variant %}
          <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
        {% endif %}
      {% endfor %}
      <input type="hidden" name="checkout" value="Checkout" />
      <button type="submit" class="cp-btn" style="width: auto; padding: 0.75rem 2rem; font-size: 1.125rem;">
        Buy Bundle Now
      </button>
    {% endform %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const stickyBar = document.getElementById('sticky-bar');
    const checkoutSection = document.getElementById('checkout-section');
    
    // Smooth scroll for hero button
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute('href')).scrollIntoView({
          behavior: 'smooth'
        });
      });
    });

    // Sticky bar observer
    window.addEventListener('scroll', function() {
      if (checkoutSection) {
        // Show sticky bar when scrolling past the hero, but hide it when reaching the actual checkout section
        const checkoutPosition = checkoutSection.getBoundingClientRect().top;
        const scrollPosition = window.scrollY;
        
        if (scrollPosition > 500 && checkoutPosition > window.innerHeight) {
           stickyBar.classList.add('visible');
        } else {
           stickyBar.classList.remove('visible');
        }
      }
    });
  });
</script>
