{% if collection.handle == 'frontpage' %}
  {% render 'homepage-bundle-gallery' %}
{% else %}
  {% paginate collection.products by 50 %}
    {% render 'shop-common' %}

    <style>
      {% if collection.handle == 'new' %}
        .shop-hero--hidden { display: none; }
        .shop-container--compact {
          padding-top: 32px;
          max-width: 1600px;
        }
        .shop-container--compact .product-grid {
          grid-template-columns: repeat(6, 1fr);
          gap: 16px;
        }
        @media (max-width: 1440px) { .shop-container--compact .product-grid { grid-template-columns: repeat(5, 1fr); } }
        @media (max-width: 1100px) { .shop-container--compact .product-grid { grid-template-columns: repeat(4, 1fr); } }
        @media (max-width: 800px)  { .shop-container--compact .product-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 540px)  { .shop-container--compact .product-grid { grid-template-columns: repeat(2, 1fr); } }

        .shop-container--compact .book-card__img-wrap {
          padding-top: 125%;
        }
        .shop-container--compact .book-card__title {
          font-size: 0.85rem;
          -webkit-line-clamp: 3;
        }
        .shop-container--compact .section-label {
          margin-bottom: 32px;
          font-size: 0.85rem;
          color: #1e293b;
          border-bottom: 2px solid #e2e8f0;
          padding-bottom: 12px;
        }
      {% endif %}

      .collection-pagination {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 40px;
        align-items: center;
        padding-bottom: 60px;
      }
      .collection-pagination a, .collection-pagination span {
        padding: 0.6rem 1.1rem;
        border-radius: 999px;
        border: 1px solid #e2e8f0;
        text-decoration: none;
        color: #0f172a;
        font-weight: 600;
        background: #fff;
      }
      .collection-pagination .current {
        background: #0f172a;
        color: #fff;
        border-color: #0f172a;
      }
    </style>

    <div class="shop-page">
      <!-- Collection Hero -->
      {% unless collection.handle == 'new' %}
        <div class="shop-hero">
          <h1>{{ collection.title }}</h1>
          {% if collection.description != blank %}
            <div class="shop-description" style="color: #94a3b8; max-width: 600px; margin: 16px auto 0; line-height: 1.6;">{{ collection.description }}</div>
          {% endif %}
        </div>
      {% endunless %}

      <div class="shop-container {% if collection.handle == 'new' %}shop-container--compact{% endif %}">
        <p class="section-label">{{ collection.title }} — {{ collection.products_count }} titles</p>

        {% if collection.products.size > 0 %}
          <div class="product-grid">
            {% for product in collection.products %}
              {% render 'book-card', product: product %}
            {% endfor %}
          </div>
        {% else %}
          <div style="text-align:center;padding:80px 24px;color:#64748b;">
            <p>No products found in this collection. Please check back soon.</p>
          </div>
        {% endif %}

        {% if paginate.pages > 1 %}
          <nav class="collection-pagination" role="navigation" aria-label="Pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}">&larr; Previous</a>
            {% endif %}

            <span class="current">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}">Next &rarr;</a>
            {% endif %}
          </nav>
        {% endif %}
      </div>
    </div>
  {% endpaginate %}

  {% if collection.products_count > 50 %}
    <script>
    (function() {
      const grid = document.querySelector('.product-grid');
      const pagination = document.querySelector('.collection-pagination');
      if (!grid || !pagination) return;

      let isLoading = false;
      let nextUrl = pagination.querySelector('a[href*="page="]:last-of-type')?.href;
      
      // If the last link is "Next", that's our nextUrl. 
      // In the liquid template, it's defined as: {% if paginate.next %}<a href="{{ paginate.next.url }}">Next &rarr;</a>{% endif %}
      const nextBtn = Array.from(pagination.querySelectorAll('a')).find(a => a.textContent.includes('Next'));
      nextUrl = nextBtn ? nextBtn.href : null;

      if (!nextUrl) return;

      const loadNextPage = async () => {
        if (isLoading || !nextUrl) return;
        isLoading = true;

        // Show a simple loading indicator
        let loader = document.getElementById('infinite-loader');
        if (!loader) {
          loader = document.createElement('div');
          loader.id = 'infinite-loader';
          loader.innerHTML = '<div style="text-align:center;padding:20px;color:#64748b;font-weight:600;">Loading more titles...</div>';
          grid.after(loader);
        }

        try {
          const response = await fetch(nextUrl);
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          
          const newProducts = doc.querySelectorAll('.product-grid > *');
          newProducts.forEach(prod => grid.appendChild(prod));

          const newPagination = doc.querySelector('.collection-pagination');
          if (newPagination) {
            const nextBtn = Array.from(newPagination.querySelectorAll('a')).find(a => a.textContent.includes('Next'));
            nextUrl = nextBtn ? nextBtn.href : null;
            // Update the "Page X of Y" text if we want, or just hide it
            pagination.style.display = 'none'; 
          } else {
            nextUrl = null;
          }

          if (!nextUrl && loader) {
            loader.remove();
          }
        } catch (e) {
          console.error('Failed to load next page:', e);
        } finally {
          isLoading = false;
        }
      };

      // Use IntersectionObserver to trigger loading when the user scrolls to the bottom
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          loadNextPage();
        }
      }, { rootMargin: '400px' });

      // Create a sentinel element at the bottom of the grid
      const sentinel = document.createElement('div');
      sentinel.style.height = '10px';
      grid.after(sentinel);
      observer.observe(sentinel);
    })();
    </script>
  {% endif %}
{% endif %}
